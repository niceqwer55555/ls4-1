{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nexport default {\n  components: {\n    Player,\n    ChatMessage,\n    SideBar\n  },\n  data() {\n    return {\n      lastMessages: null,\n      queueNumber: \"-\"\n    };\n  },\n  computed: {\n    ...mapState({\n      players1: state => state.lobby.members ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM1\") : undefined,\n      players2: state => state.lobby.members ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM2\") : undefined,\n      lobbyChatMessages: state => state.lobbyChatMessages,\n      lobbyInvites: state => state.lobby.invited,\n      inQueue: state => state.lobby.inQueue,\n      owner: state => state.lobbyOwner,\n      serverCount: state => state.serverCount,\n      botDifficulty: state => state.lobby.botDifficulty,\n      currentLobbyPlayer: state => {\n        return state.lobby.members.filter(member => {\n          return member.summonerName == state.user.summonerName;\n        })[0];\n      }\n    }),\n    canSwitchTeam() {\n      if (this.players1 && this.players2) {\n        let user = this.$store.state.user.summonerName;\n        let team1 = this.players1.some(c => c.summonerName == user);\n        let team2 = this.players2.some(c => c.summonerName == user);\n        if (team1 && this.players2.length <= 5) {\n          return true;\n        } else if (team2 && this.players1.length <= 5) {\n          return true;\n        }\n      }\n      return false;\n    }\n  },\n  methods: {\n    getMaxTeamSize() {\n      const teamSize = this.getTeamSize();\n      if (teamSize === \"5x5\") return 5;\n      if (teamSize === \"3x3\") return 3;\n      return 5;\n    },\n    isTeamFull(teamNumber) {\n      const team = teamNumber === 1 ? this.players1 : this.players2;\n      return team && team.length >= this.getMaxTeamSize();\n    },\n    hasBotInTeam(teamNumber) {\n      const team = teamNumber === 1 ? this.players1 : this.players2;\n      return team && team.some(player => player.isAI === true);\n    },\n    canJoinTeam(team) {\n      if (this.players1 && this.players2) {\n        if (team == 2) {\n          return this.players2.length != 5 && this.currentLobbyPlayer.lobbyTeam == \"TEAM1\" && this.canSwitchTeam;\n        } else {\n          return this.players1.length != 5 && this.currentLobbyPlayer.lobbyTeam == \"TEAM2\" && this.canSwitchTeam;\n        }\n      } else {\n        return false;\n      }\n    },\n    getInviteStatus(status) {\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\n    },\n    getQueueType() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"TWISTED_TREELINE_DRAFT\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\n        default:\n          return \"\";\n      }\n    },\n    getMapPreview() {\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\n        return \"static/images/general/sr-preview.png\";\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return \"static/images/general/tt-preview.png\";\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\n        return \"static/images/general/ha-preview.png\";\n      }\n      return \"static/images/general/sr-preview.png\";\n    },\n    getMapType() {\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n      }\n      return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n    },\n    getTeamSize() {\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && (lobbyType.includes(\"SUMMONERS_RIFT\") || lobbyType.includes(\"ARAM\"))) {\n        return \"5x5\";\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return \"3x3\";\n      }\n      return \"5x5\";\n    },\n    addBotToTeam(teamNumber) {\n      console.log(\"addBotToTeam called for team:\", teamNumber);\n      if (this.isTeamFull(teamNumber)) {\n        this.$modal.setter.show({\n          title: \"无法添加机器人\",\n          body: \"该队伍已达到最大人数限制\",\n          footer: \"确定\"\n        });\n        return;\n      }\n      const team = teamNumber === 1 ? \"TEAM1\" : \"TEAM2\";\n      const teamPlayers = teamNumber === 1 ? this.players1 : this.players2;\n      const botCount = teamPlayers.filter(p => p.isAI).length;\n      const botData = {\n        isAI: true,\n        aiDifficulty: this.botDifficulty || \"INTERMEDIATE\",\n        summonerName: `${this.getBotDifficultyText()} AI ${botCount + 1}`,\n        summonerLevel: 30,\n        summonerIconId: Math.floor(Math.random() * 30) + 1,\n        lobbyTeam: team,\n        isReady: true\n      };\n      console.log(\"Sending LOBBY_ADD_BOT with data:\", botData);\n      this.$socket.sendLobbyMessage(\"LOBBY_ADD_BOT\", {\n        data: botData\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\", error);\n        } else {\n          console.log(\"Bot added successfully:\", response);\n        }\n      });\n    },\n    removeBotFromTeam(teamNumber) {\n      console.log(\"removeBotFromTeam called for team:\", teamNumber);\n      const team = teamNumber === 1 ? this.players1 : this.players2;\n      const botToRemove = team.find(player => player.isAI === true);\n      if (!botToRemove) return;\n      console.log(\"Removing bot:\", botToRemove.summonerName);\n      this.$socket.sendLobbyMessage(\"LOBBY_REMOVE_BOT\", {\n        data: {\n          summonerName: botToRemove.summonerName\n        }\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\", error);\n        } else {\n          console.log(\"Bot removed successfully:\", response);\n        }\n      });\n    },\n    getBotDifficultyText() {\n      const difficulties = {\n        BEGINNER: \"入门\",\n        INTERMEDIATE: \"中等\",\n        ADVANCED: \"高级\"\n      };\n      const diff = this.botDifficulty || \"INTERMEDIATE\";\n      return difficulties[diff] || \"中等\";\n    },\n    sendLobbyChatMessage() {\n      const message = this.$refs.chatInput.value;\n      if (message.trim() == \"\") return;\n      this.$refs.chatInput.value = \"\";\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: message\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$nextTick(() => {\n          if (this.$refs.chatMessages) {\n            this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n          }\n        });\n      });\n    },\n    leaveLobby() {\n      const route = this.$route.name;\n      const router = this.$router;\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        if (route != \"Home\") {\n          router.push(\"/LoggedIn/home\");\n        }\n      });\n    },\n    startQueue() {\n      if (this.inQueue) return;\n      this.$sound.template(\"OVERVIEW_PLAYBUTTON\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_START\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n          if (error && error.message && error.code === 140) {\n            this.$store.dispatch(\"socketRecievedLobbyChat\", {\n              from: \"SYSTEM\",\n              to: null,\n              data: error.message\n            });\n          }\n        }\n        console.log(response);\n      });\n    },\n    stopQueue() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$store.dispatch(\"clearLobbyTimers\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_STOP\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$store.dispatch(\"setLobbyQueueState\", false);\n        console.log(response);\n      });\n    },\n    switchTeam() {\n      if (this.inQueue) return;\n      this.$socket.sendLobbyMessage(\"LOBBY_SWITCH_TEAM\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n      });\n    },\n    t(key, params) {\n      return this.$translate.text(key, params);\n    },\n    tWithParams(key, params) {\n      return this.$translate.text(key, params);\n    }\n  },\n  beforeMount() {\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\n    this.$store.dispatch(\"changeBackgroundState\", \"CUSTOM_LOBBY\");\n  },\n  mounted() {\n    console.log(\"LobbyCustom mounted\");\n    this.$nextTick(() => {\n      if (this.$refs.chatMessages) {\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n      }\n    });\n  },\n  updated() {\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\n      this.lastMessages = this.lobbyChatMessages.length;\n      this.$nextTick(() => {\n        if (this.$refs.chatMessages) {\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n        }\n      });\n    }\n  },\n  created() {\n    this.$store.dispatch(\"getServerCount\");\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","components","data","lastMessages","queueNumber","computed","players1","state","lobby","members","filter","c","lobbyTeam","undefined","players2","lobbyChatMessages","lobbyInvites","invited","inQueue","owner","lobbyOwner","serverCount","botDifficulty","currentLobbyPlayer","member","summonerName","user","canSwitchTeam","$store","team1","some","team2","length","methods","getMaxTeamSize","teamSize","getTeamSize","isTeamFull","teamNumber","team","hasBotInTeam","player","isAI","canJoinTeam","getInviteStatus","status","$translate","text","getQueueType","lobbyType","getMapPreview","includes","getMapType","addBotToTeam","console","log","$modal","setter","show","title","body","footer","teamPlayers","botCount","p","botData","aiDifficulty","getBotDifficultyText","summonerLevel","summonerIconId","Math","floor","random","isReady","$socket","sendLobbyMessage","response","error","removeBotFromTeam","botToRemove","find","difficulties","BEGINNER","INTERMEDIATE","ADVANCED","diff","sendLobbyChatMessage","message","$refs","chatInput","value","trim","$nextTick","chatMessages","scrollTop","scrollHeight","leaveLobby","route","$route","name","router","$router","push","startQueue","$sound","template","code","dispatch","from","to","stopQueue","switchTeam","t","key","params","tWithParams","beforeMount","mounted","updated","created"],"sources":["src/views/LobbyCustom.vue"],"sourcesContent":["<template>\r\n  <div id=\"LobbyCustom\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players\">\r\n            <div class=\"team lolblock\">\r\n              <div class=\"head\">\r\n                {{\r\n                  tWithParams(\"CTLOBBY_TEAM1_TITLE\", {\r\n                    serverCount\r\n                  })\r\n                }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <Player\r\n                  v-for=\"(player, index) in players1\"\r\n                  :key=\"index\"\r\n                  :summoner=\"player\"\r\n                  :custom=\"true\"\r\n                  :isBotGame=\"true\"\r\n                  :botDifficulty=\"botDifficulty || 'INTERMEDIATE'\"\r\n                />\r\n                <div v-if=\"canJoinTeam(1)\" class=\"joinTeam\">\r\n                  <button @click=\"switchTeam\">\r\n                    {{ t(\"CTLOBBY_JOIN_TEAM_BTN\") }}\r\n                  </button>\r\n                </div>\r\n                <!-- 机器人控制按钮 -->\r\n                <div v-if=\"owner\" class=\"bot-controls\">\r\n                  <button \r\n                    class=\"add-bot-btn\" \r\n                    @click=\"addBotToTeam(1)\"\r\n                    :disabled=\"isTeamFull(1)\"\r\n                  >\r\n                    <i class=\"fas fa-plus\"></i>\r\n                    <i class=\"fas fa-robot\"></i>\r\n                    添加AI\r\n                  </button>\r\n                  <button \r\n                    class=\"remove-bot-btn\" \r\n                    @click=\"removeBotFromTeam(1)\"\r\n                    :disabled=\"!hasBotInTeam(1)\"\r\n                  >\r\n                    <i class=\"fas fa-minus\"></i>\r\n                    <i class=\"fas fa-robot\"></i>\r\n                    移除AI\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"team lolblock\">\r\n              <div class=\"head\">\r\n                {{ t(\"CTLOBBY_TEAM2_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <Player\r\n                  v-for=\"(player, index) in players2\"\r\n                  :key=\"index\"\r\n                  :summoner=\"player\"\r\n                  :custom=\"true\"\r\n                  :isBotGame=\"true\"\r\n                  :botDifficulty=\"botDifficulty || 'INTERMEDIATE'\"\r\n                />\r\n                <div v-if=\"canJoinTeam(2)\" class=\"joinTeam\">\r\n                  <button @click=\"switchTeam\">\r\n                    {{ t(\"CTLOBBY_JOIN_TEAM_BTN\") }}\r\n                  </button>\r\n                </div>\r\n                <!-- 机器人控制按钮 -->\r\n                <div v-if=\"owner\" class=\"bot-controls\">\r\n                  <button \r\n                    class=\"add-bot-btn\" \r\n                    @click=\"addBotToTeam(2)\"\r\n                    :disabled=\"isTeamFull(2)\"\r\n                  >\r\n                    <i class=\"fas fa-plus\"></i>\r\n                    <i class=\"fas fa-robot\"></i>\r\n                    添加AI\r\n                  </button>\r\n                  <button \r\n                    class=\"remove-bot-btn\" \r\n                    @click=\"removeBotFromTeam(2)\"\r\n                    :disabled=\"!hasBotInTeam(2)\"\r\n                  >\r\n                    <i class=\"fas fa-minus\"></i>\r\n                    <i class=\"fas fa-robot\"></i>\r\n                    移除AI\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"actions\">\r\n              <button class=\"quitBtn\" @click=\"leaveLobby\">\r\n                {{ t(\"CTLOBBY_QUIT_GAME_BTN\") }}\r\n              </button>\r\n              <button class=\"changeBtn\" @click=\"$router.push('/LoggedIn/play')\">\r\n                {{ t(\"CTLOBBY_CHANGE_LOBBY_TYPE_BTN\") }}\r\n              </button>\r\n              <button class=\"startBtn\" v-if=\"owner\" @click=\"startQueue\">\r\n                {{ t(\"CTLOBBY_START_GAME_BTN\") }}\r\n              </button>\r\n            </div>\r\n          </div>\r\n          <div class=\"chat lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_ALLCHAT_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div class=\"chat-messages\" ref=\"chatMessages\">\r\n                <ChatMessage\r\n                  v-for=\"(message, index) in lobbyChatMessages\"\r\n                  :key=\"index\"\r\n                  :message=\"message\"\r\n                />\r\n              </div>\r\n              <div class=\"chat-input\">\r\n                <input\r\n                  type=\"text\"\r\n                  ref=\"chatInput\"\r\n                  v-on:keyup.enter=\"sendLobbyChatMessage\"\r\n                />\r\n                <button @click=\"sendLobbyChatMessage\">\r\n                  {{ t(\"LOBBY_ALLCHAT_SEND_BTN\") }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"game\">\r\n          <div class=\"map lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_MAP_OPTIONS_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <img :src=\"getMapPreview()\" class=\"preview\" alt=\"\" />\r\n              <div class=\"details\">\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_MAP\") }}:</strong>\r\n                  {{ getMapType() }}\r\n                </p>\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_TEAMSIZE\") }}:</strong>\r\n                  {{ getTeamSize() }}\r\n                </p>\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_QUEUETYPE\") }}:</strong>\r\n                  {{ getQueueType() }}\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"invites lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_INVITES_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div\r\n                class=\"invite\"\r\n                v-for=\"(invite, index) in lobbyInvites\"\r\n                :key=\"index\"\r\n              >\r\n                <span>{{ index }}</span>\r\n                <span :class=\"invite.toLowerCase()\">\r\n                  {{ getInviteStatus(invite) }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    ChatMessage,\r\n    SideBar\r\n  },\r\n  data() {\r\n    return {\r\n      lastMessages: null,\r\n      queueNumber: \"-\"\r\n    };\r\n  },\r\n  computed: {\r\n    ...mapState({\r\n      players1: state =>\r\n        state.lobby.members\r\n          ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM1\")\r\n          : undefined,\r\n      players2: state =>\r\n        state.lobby.members\r\n          ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM2\")\r\n          : undefined,\r\n      lobbyChatMessages: state => state.lobbyChatMessages,\r\n      lobbyInvites: state => state.lobby.invited,\r\n      inQueue: state => state.lobby.inQueue,\r\n      owner: state => state.lobbyOwner,\r\n      serverCount: state => state.serverCount,\r\n      botDifficulty: state => state.lobby.botDifficulty,\r\n      currentLobbyPlayer: state => {\r\n        return state.lobby.members.filter(member => {\r\n          return member.summonerName == state.user.summonerName;\r\n        })[0];\r\n      }\r\n    }),\r\n    \r\n    canSwitchTeam() {\r\n      if (this.players1 && this.players2) {\r\n        let user = this.$store.state.user.summonerName;\r\n        let team1 = this.players1.some(c => c.summonerName == user);\r\n        let team2 = this.players2.some(c => c.summonerName == user);\r\n\r\n        if (team1 && this.players2.length <= 5) {\r\n          return true;\r\n        } else if (team2 && this.players1.length <= 5) {\r\n          return true;\r\n        }\r\n      }\r\n      return false;\r\n    }\r\n  },\r\n  methods: {\r\n    getMaxTeamSize() {\r\n      const teamSize = this.getTeamSize();\r\n      if (teamSize === \"5x5\") return 5;\r\n      if (teamSize === \"3x3\") return 3;\r\n      return 5;\r\n    },\r\n    \r\n    isTeamFull(teamNumber) {\r\n      const team = teamNumber === 1 ? this.players1 : this.players2;\r\n      return team && team.length >= this.getMaxTeamSize();\r\n    },\r\n    \r\n    hasBotInTeam(teamNumber) {\r\n      const team = teamNumber === 1 ? this.players1 : this.players2;\r\n      return team && team.some(player => player.isAI === true);\r\n    },\r\n    \r\n    canJoinTeam(team) {\r\n      if (this.players1 && this.players2) {\r\n        if (team == 2) {\r\n          return (\r\n            this.players2.length != 5 &&\r\n            this.currentLobbyPlayer.lobbyTeam == \"TEAM1\" &&\r\n            this.canSwitchTeam\r\n          );\r\n        } else {\r\n          return (\r\n            this.players1.length != 5 &&\r\n            this.currentLobbyPlayer.lobbyTeam == \"TEAM2\" &&\r\n            this.canSwitchTeam\r\n          );\r\n        }\r\n      } else {\r\n        return false;\r\n      }\r\n    },\r\n    \r\n    getInviteStatus(status) {\r\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\r\n    },\r\n    \r\n    getQueueType() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\r\n        default:\r\n          return \"\";\r\n      }\r\n    },\r\n    \r\n    getMapPreview() {\r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\r\n        return \"static/images/general/sr-preview.png\";\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return \"static/images/general/tt-preview.png\";\r\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\r\n        return \"static/images/general/ha-preview.png\";\r\n      }\r\n      return \"static/images/general/sr-preview.png\";\r\n    },\r\n    \r\n    getMapType() {\r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\r\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\r\n      }\r\n      return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n    },\r\n    \r\n    getTeamSize() {\r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && (lobbyType.includes(\"SUMMONERS_RIFT\") || lobbyType.includes(\"ARAM\"))) {\r\n        return \"5x5\";\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return \"3x3\";\r\n      }\r\n      return \"5x5\";\r\n    },\r\n    \r\n    addBotToTeam(teamNumber) {\r\n      console.log(\"addBotToTeam called for team:\", teamNumber);\r\n      if (this.isTeamFull(teamNumber)) {\r\n        this.$modal.setter.show({\r\n          title: \"无法添加机器人\",\r\n          body: \"该队伍已达到最大人数限制\",\r\n          footer: \"确定\"\r\n        });\r\n        return;\r\n      }\r\n      \r\n      const team = teamNumber === 1 ? \"TEAM1\" : \"TEAM2\";\r\n      const teamPlayers = teamNumber === 1 ? this.players1 : this.players2;\r\n      const botCount = teamPlayers.filter(p => p.isAI).length;\r\n      \r\n      const botData = {\r\n        isAI: true,\r\n        aiDifficulty: this.botDifficulty || \"INTERMEDIATE\",\r\n        summonerName: `${this.getBotDifficultyText()} AI ${botCount + 1}`,\r\n        summonerLevel: 30,\r\n        summonerIconId: Math.floor(Math.random() * 30) + 1,\r\n        lobbyTeam: team,\r\n        isReady: true\r\n      };\r\n      \r\n      console.log(\"Sending LOBBY_ADD_BOT with data:\", botData);\r\n      \r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_ADD_BOT\",\r\n        { data: botData },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\", error);\r\n          } else {\r\n            console.log(\"Bot added successfully:\", response);\r\n          }\r\n        }\r\n      );\r\n    },\r\n    \r\n    removeBotFromTeam(teamNumber) {\r\n      console.log(\"removeBotFromTeam called for team:\", teamNumber);\r\n      const team = teamNumber === 1 ? this.players1 : this.players2;\r\n      const botToRemove = team.find(player => player.isAI === true);\r\n      \r\n      if (!botToRemove) return;\r\n      \r\n      console.log(\"Removing bot:\", botToRemove.summonerName);\r\n      \r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_REMOVE_BOT\",\r\n        { data: { summonerName: botToRemove.summonerName } },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\", error);\r\n          } else {\r\n            console.log(\"Bot removed successfully:\", response);\r\n          }\r\n        }\r\n      );\r\n    },\r\n    \r\n    getBotDifficultyText() {\r\n      const difficulties = {\r\n        BEGINNER: \"入门\",\r\n        INTERMEDIATE: \"中等\",\r\n        ADVANCED: \"高级\"\r\n      };\r\n      const diff = this.botDifficulty || \"INTERMEDIATE\";\r\n      return difficulties[diff] || \"中等\";\r\n    },\r\n    \r\n    sendLobbyChatMessage() {\r\n      const message = this.$refs.chatInput.value;\r\n      if (message.trim() == \"\") return;\r\n      this.$refs.chatInput.value = \"\";\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_CHAT\",\r\n        { data: message },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n          this.$nextTick(() => {\r\n            if (this.$refs.chatMessages) {\r\n              this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n            }\r\n          });\r\n        }\r\n      );\r\n    },\r\n    \r\n    leaveLobby() {\r\n      const route = this.$route.name;\r\n      const router = this.$router;\r\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\r\n        if (error) {\r\n          console.log(\"Flyback error:\");\r\n          console.log(error);\r\n        }\r\n        if (route != \"Home\") {\r\n          router.push(\"/LoggedIn/home\");\r\n        }\r\n      });\r\n    },\r\n    \r\n    startQueue() {\r\n      if (this.inQueue) return;\r\n\r\n      this.$sound.template(\"OVERVIEW_PLAYBUTTON\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_START\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n\r\n            if (error && error.message && error.code === 140) {\r\n              this.$store.dispatch(\"socketRecievedLobbyChat\", {\r\n                from: \"SYSTEM\",\r\n                to: null,\r\n                data: error.message\r\n              });\r\n            }\r\n          }\r\n\r\n          console.log(response);\r\n        }\r\n      );\r\n    },\r\n    \r\n    stopQueue() {\r\n      this.$sound.template(\"OVERVIEW_CLICK\");\r\n      this.$store.dispatch(\"clearLobbyTimers\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_STOP\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n          this.$store.dispatch(\"setLobbyQueueState\", false);\r\n\r\n          console.log(response);\r\n        }\r\n      );\r\n    },\r\n    \r\n    switchTeam() {\r\n      if (this.inQueue) return;\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_SWITCH_TEAM\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n        }\r\n      );\r\n    },\r\n    \r\n    t(key, params) {\r\n      return this.$translate.text(key, params);\r\n    },\r\n    \r\n    tWithParams(key, params) {\r\n      return this.$translate.text(key, params);\r\n    }\r\n  },\r\n  beforeMount() {\r\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\r\n    this.$store.dispatch(\"changeBackgroundState\", \"CUSTOM_LOBBY\");\r\n  },\r\n  mounted() {\r\n    console.log(\"LobbyCustom mounted\");\r\n    this.$nextTick(() => {\r\n      if (this.$refs.chatMessages) {\r\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n      }\r\n    });\r\n  },\r\n  updated() {\r\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\r\n      this.lastMessages = this.lobbyChatMessages.length;\r\n      this.$nextTick(() => {\r\n        if (this.$refs.chatMessages) {\r\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n