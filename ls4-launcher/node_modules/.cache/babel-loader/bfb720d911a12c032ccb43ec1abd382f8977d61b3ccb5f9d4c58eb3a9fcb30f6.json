{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nexport default {\n  components: {\n    Player,\n    ChatMessage,\n    SideBar\n  },\n  data() {\n    return {\n      lastMessages: null,\n      showBotModal: false,\n      newBotDifficulty: \"MEDIUM\",\n      newBotChampion: 1,\n      newBotTeam: 100,\n      availableBots: [{\n        id: 1,\n        name: \"安妮\"\n      }, {\n        id: 2,\n        name: \"奥拉夫\"\n      }, {\n        id: 3,\n        name: \"加里奥\"\n      }, {\n        id: 4,\n        name: \"崔斯塔娜\"\n      }, {\n        id: 5,\n        name: \"索拉卡\"\n      }, {\n        id: 6,\n        name: \"盖伦\"\n      }, {\n        id: 7,\n        name: \"艾希\"\n      }, {\n        id: 8,\n        name: \"提莫\"\n      }, {\n        id: 9,\n        name: \"剑圣\"\n      }, {\n        id: 10,\n        name: \"瑞兹\"\n      }],\n      localBots: {\n        100: [],\n        200: []\n      }\n    };\n  },\n  computed: {\n    ...mapState({\n      players: state => state.lobby.members,\n      lobbyChatMessages: state => state.lobbyChatMessages,\n      lobbyInvites: state => state.lobby.invited,\n      inQueue: state => state.lobby.inQueue,\n      owner: state => state.lobbyOwner,\n      queueNumber: state => state.lobbyQueueCount,\n      serverCount: state => state.serverCount\n    }),\n    isCustomOrBotLobby() {\n      const type = this.$store.state.lobby.lobbyType || \"\";\n      return type.startsWith(\"COOP_\") || type.startsWith(\"CUSTOM_\");\n    },\n    isBotLobby() {\n      const type = this.$store.state.lobby.lobbyType || \"\";\n      return type.startsWith(\"COOP_\");\n    },\n    botDifficultyText() {\n      const type = this.$store.state.lobby.lobbyType || \"\";\n      if (type.includes(\"BOT_EASY\")) return \"简单\";\n      if (type.includes(\"BOT_HARD\")) return \"困难\";\n      return \"一般\";\n    },\n    maxTeamSize() {\n      const type = this.$store.state.lobby.lobbyType || \"\";\n      return type.includes(\"TWISTED_TREELINE\") || type.includes(\"TT_\") ? 3 : 5;\n    },\n    botTeammates() {\n      return this.localBots[100];\n    },\n    enemyBots() {\n      return this.localBots[200];\n    }\n  },\n  methods: {\n    openAddBotModal(teamId = 100) {\n      if (!this.owner) return;\n      this.newBotTeam = teamId;\n      this.showBotModal = true;\n    },\n    closeBotModal() {\n      this.showBotModal = false;\n    },\n    addBotToLobby() {\n      if (!this.owner) return;\n      const botData = {\n        championId: this.newBotChampion,\n        botDifficulty: this.newBotDifficulty,\n        teamId: this.newBotTeam\n      };\n      this.$socket.sendLobbyMessage(\"LOBBY_ADD_BOT\", botData, (response, error) => {\n        if (error) {\n          console.error(\"添加机器人失败\", error);\n          return;\n        }\n        this.localBots[this.newBotTeam].push({\n          summonerName: `${this.getChampName(this.newBotChampion)}(AI ${this.newBotDifficulty})`,\n          isBot: true,\n          level: 30,\n          icon: 1,\n          botDifficulty: this.newBotDifficulty,\n          championId: this.newBotChampion\n        });\n        this.closeBotModal();\n      });\n    },\n    removeBot(index, teamId) {\n      if (!this.owner) return;\n      const bot = this.localBots[teamId][index];\n      this.$socket.sendLobbyMessage(\"LOBBY_REMOVE_BOT\", {\n        championId: bot.championId,\n        teamId\n      }, () => {\n        this.localBots[teamId].splice(index, 1);\n      });\n    },\n    getChampName(id) {\n      const c = this.availableBots.find(b => b.id === id);\n      return c ? c.name : \"机器人\";\n    },\n    startBotGame() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {}, res => {\n        if (res.success) {\n          this.$router.push(\"/gameLoading\");\n        }\n      });\n    },\n    getInviteStatus(status) {\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\n    },\n    getQueueType() {\n      const type = this.$store.state.lobby.lobbyType;\n      switch (type) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"TWISTED_TREELINE_DRAFT\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\n        case \"COOP_VS_AI_BOT_EASY\":\n        case \"COOP_VS_AI_BOT_NORMAL\":\n        case \"COOP_VS_AI_BOT_HARD\":\n          return \"人机训练\";\n        default:\n          if (type.startsWith(\"CUSTOM_\")) return \"自定义游戏\";\n          return \"标准模式\";\n      }\n    },\n    getMapPreview() {\n      const type = this.$store.state.lobby.lobbyType;\n      if (type.includes(\"SUMMONERS_RIFT\") || type.includes(\"COOP_VS_AI\") || type.includes(\"CUSTOM_SR\")) {\n        return \"static/images/general/sr-preview.png\";\n      }\n      if (type.includes(\"TWISTED_TREELINE\") || type.includes(\"COOP_TT\") || type.includes(\"CUSTOM_TT\")) {\n        return \"static/images/general/tt-preview.png\";\n      }\n      if (type.includes(\"ARAM\") || type.includes(\"COOP_ARAM\")) {\n        return \"static/images/general/ha-preview.png\";\n      }\n      return \"static/images/general/sr-preview.png\";\n    },\n    getMapType() {\n      const type = this.$store.state.lobby.lobbyType;\n      if (type.includes(\"SUMMONERS_RIFT\") || type.includes(\"COOP_VS_AI\") || type.includes(\"CUSTOM_SR\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n      }\n      if (type.includes(\"TWISTED_TREELINE\") || type.includes(\"COOP_TT\") || type.includes(\"CUSTOM_TT\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n      }\n      if (type.includes(\"ARAM\") || type.includes(\"COOP_ARAM\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n      }\n      return \"召唤师峡谷\";\n    },\n    getTeamSize() {\n      const type = this.$store.state.lobby.lobbyType;\n      return type.includes(\"TWISTED_TREELINE\") || type.includes(\"TT_\") || type.includes(\"COOP_TT\") ? \"3x3\" : \"5x5\";\n    },\n    sendLobbyChatMessage() {\n      const message = this.$refs.chatInput.value.trim();\n      if (!message) return;\n      this.$refs.chatInput.value = \"\";\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: message\n      }, () => {\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n      });\n    },\n    leaveLobby() {\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, () => {\n        this.$router.push(\"/LoggedIn/home\");\n      });\n    },\n    startQueue() {\n      if (this.inQueue) return;\n      this.$sound.template(\"CORE_QUEUE_START\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_START\", {}, err => {\n        if (!err) this.$sound.template(\"CORE_MUSIC_QUEUE\");\n      });\n    },\n    stopQueue() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$store.dispatch(\"clearLobbyTimers\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_STOP\", {}, () => {\n        this.$store.dispatch(\"setLobbyQueueState\", false);\n      });\n      this.$sound.stopAllLoops(\"CORE_MUSIC\");\n    }\n  },\n  beforeMount() {\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\n    this.$store.dispatch(\"changeBackgroundState\", \"LOBBY\");\n  },\n  updated() {\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\n      this.lastMessages = this.lobbyChatMessages.length;\n      this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n    }\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","components","data","lastMessages","showBotModal","newBotDifficulty","newBotChampion","newBotTeam","availableBots","id","name","localBots","computed","players","state","lobby","members","lobbyChatMessages","lobbyInvites","invited","inQueue","owner","lobbyOwner","queueNumber","lobbyQueueCount","serverCount","isCustomOrBotLobby","type","$store","lobbyType","startsWith","isBotLobby","botDifficultyText","includes","maxTeamSize","botTeammates","enemyBots","methods","openAddBotModal","teamId","closeBotModal","addBotToLobby","botData","championId","botDifficulty","$socket","sendLobbyMessage","response","error","console","push","summonerName","getChampName","isBot","level","icon","removeBot","index","bot","splice","c","find","b","startBotGame","$sound","template","res","success","$router","getInviteStatus","status","$translate","text","getQueueType","getMapPreview","getMapType","getTeamSize","sendLobbyChatMessage","message","$refs","chatInput","value","trim","chatMessages","scrollTop","scrollHeight","leaveLobby","startQueue","err","stopQueue","dispatch","stopAllLoops","beforeMount","updated","length"],"sources":["src/views/Lobby.vue"],"sourcesContent":["<template>\r\n  <div id=\"Lobby\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players lolblock\">\r\n            <div class=\"head\">\r\n              {{\r\n                tWithParams(\"LOBBY_YOUR_TEAM_QUEUE\", {\r\n                  queueNumber,\r\n                  serverCount\r\n                })\r\n              }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <!-- 真实玩家 -->\r\n              <Player\r\n                v-for=\"(player, index) in players\"\r\n                :key=\"'player_' + index\"\r\n                :summoner=\"player\"\r\n              />\r\n\r\n              <!-- 机器人队友 -->\r\n              <Player\r\n                v-for=\"(bot, index) in botTeammates\"\r\n                :key=\"'bot_' + index\"\r\n                :summoner=\"bot\"\r\n                :is-bot=\"true\"\r\n                @remove=\"removeBot(index, 100)\"\r\n              />\r\n\r\n              <!-- 添加机器人按钮 (己方) -->\r\n              <div\r\n                class=\"bot-slot\"\r\n                v-if=\"owner && isCustomOrBotLobby\"\r\n              >\r\n                <button class=\"add-bot-btn\" @click=\"openAddBotModal(100)\">\r\n                  + 添加己方机器人\r\n                </button>\r\n              </div>\r\n\r\n              <!-- 敌方队伍 -->\r\n              <div class=\"enemy-team\" v-if=\"isCustomOrBotLobby\">\r\n                <div class=\"enemy-header\">敌方队伍</div>\r\n                <Player\r\n                  v-for=\"(bot, index) in enemyBots\"\r\n                  :key=\"'enemy_' + index\"\r\n                  :summoner=\"bot\"\r\n                  :is-bot=\"true\"\r\n                  @remove=\"removeBot(index, 200)\"\r\n                />\r\n\r\n                <!-- 添加机器人按钮 (敌方) -->\r\n                <div\r\n                  class=\"bot-slot\"\r\n                  v-if=\"owner\"\r\n                >\r\n                  <button class=\"add-bot-btn\" @click=\"openAddBotModal(200)\">\r\n                    + 添加敌方机器人\r\n                  </button>\r\n                </div>\r\n              </div>\r\n\r\n              <div class=\"actions\">\r\n                <button class=\"cancelBtn\" v-if=\"!inQueue\" @click=\"leaveLobby\">\r\n                  {{ t(\"LOBBY_CANCEL_BTN\") }}\r\n                </button>\r\n                <button\r\n                  v-if=\"!inQueue && owner\"\r\n                  class=\"changeBtn\"\r\n                  @click=\"$router.push('/LoggedIn/play')\"\r\n                >\r\n                  {{ t(\"LOBBY_CHANGE_LOBBY_TYPE\") }}\r\n                </button>\r\n\r\n                <!-- 人机/自定义开始按钮 -->\r\n                <button\r\n                  v-if=\"owner && isCustomOrBotLobby\"\r\n                  class=\"startBtn\"\r\n                  @click=\"startBotGame\"\r\n                >\r\n                  {{ t(\"LOBBY_START_GAME\") }}\r\n                </button>\r\n\r\n                <button\r\n                  v-else-if=\"!owner && inQueue\"\r\n                  class=\"startBtn\"\r\n                  @click=\"stopQueue\"\r\n                >\r\n                  {{ t(\"LOBBY_STOP_QUEUE\") }}\r\n                </button>\r\n                <button\r\n                  v-else-if=\"owner && !isCustomOrBotLobby\"\r\n                  class=\"startBtn\"\r\n                  @click=\"inQueue ? stopQueue() : startQueue()\"\r\n                >\r\n                  {{ inQueue ? t(\"LOBBY_STOP_QUEUE\") : t(\"LOBBY_START_QUEUE\") }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"game\">\r\n            <div class=\"map lolblock\">\r\n              <div class=\"head\">{{ t(\"LOBBY_MAP_OPTIONS_TITLE\") }}</div>\r\n              <div class=\"inner\">\r\n                <img :src=\"getMapPreview()\" class=\"preview\" alt=\"\" />\r\n                <div class=\"details\">\r\n                  <p>\r\n                    <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_MAP\") }}:</strong>\r\n                    {{ getMapType() }}\r\n                  </p>\r\n                  <p>\r\n                    <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_TEAMSIZE\") }}:</strong>\r\n                    {{ getTeamSize() }}\r\n                  </p>\r\n                  <p>\r\n                    <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_QUEUETYPE\") }}:</strong>\r\n                    {{ getQueueType() }}\r\n                  </p>\r\n                  <p v-if=\"isBotLobby\">\r\n                    <strong>难度:</strong> {{ botDifficultyText }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n\r\n            <div class=\"invites lolblock\">\r\n              <div class=\"head\">{{ t(\"LOBBY_INVITES_TITLE\") }}</div>\r\n              <div class=\"inner\">\r\n                <div\r\n                  class=\"invite\"\r\n                  v-for=\"(invite, index) in lobbyInvites\"\r\n                  :key=\"index\"\r\n                >\r\n                  <span>{{ invite.summonerName }}</span>\r\n                  <span :class=\"invite.status.toLowerCase()\">\r\n                    {{ getInviteStatus(invite.status) }}\r\n                  </span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"chat lolblock\">\r\n          <div class=\"head\">{{ t(\"LOBBY_ALLCHAT_TITLE\") }}</div>\r\n          <div class=\"inner\">\r\n            <div class=\"chat-messages\" ref=\"chatMessages\">\r\n              <ChatMessage\r\n                v-for=\"(message, index) in lobbyChatMessages\"\r\n                :key=\"index\"\r\n                :message=\"message\"\r\n              />\r\n            </div>\r\n            <div class=\"chat-input\">\r\n              <input\r\n                type=\"text\"\r\n                ref=\"chatInput\"\r\n                v-on:keyup.enter=\"sendLobbyChatMessage\"\r\n              />\r\n              <button @click=\"sendLobbyChatMessage\">\r\n                {{ t(\"LOBBY_ALLCHAT_SEND_BTN\") }}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n\r\n    <!-- 添加机器人弹窗 -->\r\n    <div class=\"bot-modal\" v-if=\"showBotModal\" @click.self=\"closeBotModal\">\r\n      <div class=\"modal-content\">\r\n        <div class=\"modal-head\">\r\n          <h3>添加机器人</h3>\r\n          <button class=\"close-btn\" @click=\"closeBotModal\">×</button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <div class=\"form-group\">\r\n            <label>难度</label>\r\n            <select v-model=\"newBotDifficulty\">\r\n              <option value=\"EASY\">简单</option>\r\n              <option value=\"MEDIUM\">一般</option>\r\n              <option value=\"HARD\">困难</option>\r\n            </select>\r\n          </div>\r\n          <div class=\"form-group\">\r\n            <label>英雄</label>\r\n            <select v-model=\"newBotChampion\">\r\n              <option\r\n                v-for=\"champ in availableBots\"\r\n                :key=\"champ.id\"\r\n                :value=\"champ.id\"\r\n              >\r\n                {{ champ.name }}\r\n              </option>\r\n            </select>\r\n          </div>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button class=\"confirm-btn\" @click=\"addBotToLobby\">确认添加</button>\r\n          <button class=\"cancel-btn\" @click=\"closeBotModal\">取消</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    ChatMessage,\r\n    SideBar\r\n  },\r\n  data() {\r\n    return {\r\n      lastMessages: null,\r\n      showBotModal: false,\r\n      newBotDifficulty: \"MEDIUM\",\r\n      newBotChampion: 1,\r\n      newBotTeam: 100,\r\n      availableBots: [\r\n        { id: 1, name: \"安妮\" },\r\n        { id: 2, name: \"奥拉夫\" },\r\n        { id: 3, name: \"加里奥\" },\r\n        { id: 4, name: \"崔斯塔娜\" },\r\n        { id: 5, name: \"索拉卡\" },\r\n        { id: 6, name: \"盖伦\" },\r\n        { id: 7, name: \"艾希\" },\r\n        { id: 8, name: \"提莫\" },\r\n        { id: 9, name: \"剑圣\" },\r\n        { id: 10, name: \"瑞兹\" }\r\n      ],\r\n      localBots: {\r\n        100: [],\r\n        200: []\r\n      }\r\n    };\r\n  },\r\n  computed: {\r\n    ...mapState({\r\n      players: state => state.lobby.members,\r\n      lobbyChatMessages: state => state.lobbyChatMessages,\r\n      lobbyInvites: state => state.lobby.invited,\r\n      inQueue: state => state.lobby.inQueue,\r\n      owner: state => state.lobbyOwner,\r\n      queueNumber: state => state.lobbyQueueCount,\r\n      serverCount: state => state.serverCount\r\n    }),\r\n\r\n    isCustomOrBotLobby() {\r\n      const type = this.$store.state.lobby.lobbyType || \"\";\r\n      return type.startsWith(\"COOP_\") || type.startsWith(\"CUSTOM_\");\r\n    },\r\n\r\n    isBotLobby() {\r\n      const type = this.$store.state.lobby.lobbyType || \"\";\r\n      return type.startsWith(\"COOP_\");\r\n    },\r\n\r\n    botDifficultyText() {\r\n      const type = this.$store.state.lobby.lobbyType || \"\";\r\n      if (type.includes(\"BOT_EASY\")) return \"简单\";\r\n      if (type.includes(\"BOT_HARD\")) return \"困难\";\r\n      return \"一般\";\r\n    },\r\n\r\n    maxTeamSize() {\r\n      const type = this.$store.state.lobby.lobbyType || \"\";\r\n      return type.includes(\"TWISTED_TREELINE\") || type.includes(\"TT_\") ? 3 : 5;\r\n    },\r\n\r\n    botTeammates() {\r\n      return this.localBots[100];\r\n    },\r\n\r\n    enemyBots() {\r\n      return this.localBots[200];\r\n    }\r\n  },\r\n\r\n  methods: {\r\n    openAddBotModal(teamId = 100) {\r\n      if (!this.owner) return;\r\n      this.newBotTeam = teamId;\r\n      this.showBotModal = true;\r\n    },\r\n\r\n    closeBotModal() {\r\n      this.showBotModal = false;\r\n    },\r\n\r\n    addBotToLobby() {\r\n      if (!this.owner) return;\r\n\r\n      const botData = {\r\n        championId: this.newBotChampion,\r\n        botDifficulty: this.newBotDifficulty,\r\n        teamId: this.newBotTeam\r\n      };\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_ADD_BOT\",\r\n        botData,\r\n        (response, error) => {\r\n          if (error) {\r\n            console.error(\"添加机器人失败\", error);\r\n            return;\r\n          }\r\n          this.localBots[this.newBotTeam].push({\r\n            summonerName: `${this.getChampName(\r\n              this.newBotChampion\r\n            )}(AI ${this.newBotDifficulty})`,\r\n            isBot: true,\r\n            level: 30,\r\n            icon: 1,\r\n            botDifficulty: this.newBotDifficulty,\r\n            championId: this.newBotChampion\r\n          });\r\n          this.closeBotModal();\r\n        }\r\n      );\r\n    },\r\n\r\n    removeBot(index, teamId) {\r\n      if (!this.owner) return;\r\n      const bot = this.localBots[teamId][index];\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_REMOVE_BOT\",\r\n        { championId: bot.championId, teamId },\r\n        () => {\r\n          this.localBots[teamId].splice(index, 1);\r\n        }\r\n      );\r\n    },\r\n\r\n    getChampName(id) {\r\n      const c = this.availableBots.find(b => b.id === id);\r\n      return c ? c.name : \"机器人\";\r\n    },\r\n\r\n    startBotGame() {\r\n      this.$sound.template(\"OVERVIEW_CLICK\");\r\n      this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {}, (res) => {\r\n        if (res.success) {\r\n          this.$router.push(\"/gameLoading\");\r\n        }\r\n      });\r\n    },\r\n\r\n    getInviteStatus(status) {\r\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\r\n    },\r\n\r\n    getQueueType() {\r\n      const type = this.$store.state.lobby.lobbyType;\r\n      switch (type) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\r\n        case \"COOP_VS_AI_BOT_EASY\":\r\n        case \"COOP_VS_AI_BOT_NORMAL\":\r\n        case \"COOP_VS_