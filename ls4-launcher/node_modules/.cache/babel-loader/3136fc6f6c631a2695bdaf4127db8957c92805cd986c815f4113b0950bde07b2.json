ser Quintessence of Magic Resist\",\n        5273: \"Greater Mark of Attack Speed\",\n        5274: \"Mark of Attack Speed\",\n        5275: \"Lesser Mark of Attack Speed\",\n        5296: \"Greater Seal of Movement Speed\",\n        5297: \"Seal of Movement Speed\",\n        5298: \"Lesser Seal of Movement Speed\",\n        5305: \"Greater Glyph of Life Steal\",\n        5306: \"Glyph of Life Steal\",\n        5307: \"Lesser Glyph of Life Steal\",\n        5311: \"Greater Quintessence of Spell Vamp\",\n        5312: \"Quintessence of Spell Vamp\",\n        5313: \"Lesser Quintessence of Spell Vamp\",\n        5265: \"Greater Mark of Gold per 10\",\n        5266: \"Mark of Gold per 10\",\n        5267: \"Lesser Mark of Gold per 10\",\n        5277: \"Greater Seal of Health\",\n        5278: \"Seal of Health\",\n        5279: \"Lesser Seal of Health\",\n        5280: \"Greater Glyph of Health Regeneration\",\n        5281: \"Glyph of Health Regeneration\",\n        5282: \"Lesser Glyph of Health Regeneration\",\n        5283: \"Greater Quintessence of Mana\",\n        5284: \"Quintessence of Mana\",\n        5285: \"Lesser Quintessence of Mana\",\n        5286: \"Greater Mark of Mana Regeneration\",\n        5287: \"Mark of Mana Regeneration\",\n        5288: \"Lesser Mark of Mana Regeneration\",\n        5302: \"Greater Seal of Cooldown Reduction\",\n        5303: \"Seal of Cooldown Reduction\",\n        5304: \"Lesser Seal of Cooldown Reduction\",\n        5320: \"Greater Glyph of Critical Strike\",\n        5321: \"Glyph of Critical Strike\",\n        5322: \"Lesser Glyph of Critical Strike\"\n      };\n      return runeNames[runeId] || \"Unknown Rune\";\n    },\n    saveCurrentPageName() {\n      if (this.currentPageName.trim()) {\n        const updatedPages = [...this.runePages];\n        updatedPages[this.currentRunePage] = {\n          ...updatedPages[this.currentRunePage],\n          name: this.currentPageName.trim()\n        };\n        this.$store.commit(\"