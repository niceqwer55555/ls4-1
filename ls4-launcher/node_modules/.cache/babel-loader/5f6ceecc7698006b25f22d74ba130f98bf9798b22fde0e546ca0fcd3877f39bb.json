{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nimport moment from \"moment\";\nexport default {\n  components: {\n    Player,\n    ChatMessage,\n    SideBar\n  },\n  data() {\n    return {\n      lastMessages: null\n    };\n  },\n  computed: mapState({\n    players: state => state.lobby.members,\n    lobbyChatMessages: state => state.lobbyChatMessages,\n    lobbyInvites: state => state.lobby.invited,\n    inQueue: state => state.lobby.inQueue,\n    owner: state => state.lobbyOwner,\n    queueNumber: state => state.lobbyQueueCount,\n    serverCount: state => state.serverCount,\n    isBotGame: state => state.lobby.isBotGame || false,\n    botDifficulty: state => state.lobby.botDifficulty,\n    isCustomGame: state => state.lobby.isCustom || false,\n    isHumanPlayer: state => {\n      if (!state.lobby.isBotGame) return true;\n      const currentUser = state.user.summonerName;\n      return state.lobby.members.some(member => member.summonerName === currentUser && !member.isAI);\n    },\n    humanPlayersCount: state => {\n      if (!state.lobby.isBotGame) return 0;\n      return state.lobby.members.filter(member => !member.isAI).length;\n    },\n    canStartBotGame: state => {\n      if (!state.lobby.isBotGame) return true;\n      return state.lobby.members.some(member => !member.isAI);\n    }\n  }),\n  methods: {\n    getMaxPlayers() {\n      const teamSize = this.getTeamSize();\n      if (teamSize === \"5x5\") return 5;\n      if (teamSize === \"3x3\") return 3;\n      return 5;\n    },\n    getInviteStatus(status) {\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\n    },\n    getBotDifficultyText() {\n      const difficulties = {\n        BEGINNER: this.$translate.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\"),\n        INTERMEDIATE: this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\"),\n        ADVANCED: this.$translate.text(\"PLAY_DATA_DIFFICULTY_ADVANCED\")\n      };\n      return difficulties[this.botDifficulty] || this.botDifficulty || this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\");\n    },\n    getBotDifficultyDescription() {\n      const descriptions = {\n        BEGINNER: this.$translate.text(\"LOBBY_AI_DIFFICULTY_BEGINNER_DESC\"),\n        INTERMEDIATE: this.$translate.text(\"LOBBY_AI_DIFFICULTY_INTERMEDIATE_DESC\"),\n        ADVANCED: this.$translate.text(\"LOBBY_AI_DIFFICULTY_ADVANCED_DESC\")\n      };\n      return descriptions[this.botDifficulty] || this.$translate.text(\"LOBBY_AI_DEFAULT_DESC\");\n    },\n    getStartButtonText() {\n      if (this.isBotGame) {\n        if (!this.canStartBotGame) {\n          return this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS\");\n        }\n        return this.inQueue ? this.$translate.text(\"LOBBY_STOP_QUEUE\") : this.$translate.text(\"LOBBY_START_GAME\");\n      }\n      return this.inQueue ? this.$translate.text(\"LOBBY_STOP_QUEUE\") : this.$translate.text(\"LOBBY_START_QUEUE\");\n    },\n    getChatPlaceholder() {\n      if (this.isBotGame && !this.isHumanPlayer) {\n        return this.$translate.text(\"LOBBY_AI_CANNOT_CHAT\");\n      }\n      return this.$translate.text(\"LOBBY_ALLCHAT_PLACEHOLDER\");\n    },\n    getQueueType() {\n      if (this.isBotGame) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_BOT\");\n      }\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      switch (lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"TWISTED_TREELINE_DRAFT\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\n        default:\n          return \"\";\n      }\n    },\n    getMapPreview() {\n      if (this.isBotGame && this.$store.state.lobby.mapCode) {\n        const mapCode = this.$store.state.lobby.mapCode;\n        if (mapCode === \"SUMMONERS_RIFT\") {\n          return \"static/images/general/sr-preview.png\";\n        } else if (mapCode === \"TWISTED_TREELINE\") {\n          return \"static/images/general/tt-preview.png\";\n        } else if (mapCode === \"ARAM\") {\n          return \"static/images/general/ha-preview.png\";\n        }\n      }\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\n        return \"static/images/general/sr-preview.png\";\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return \"static/images/general/tt-preview.png\";\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\n        return \"static/images/general/ha-preview.png\";\n      }\n      return \"static/images/general/sr-preview.png\";\n    },\n    getMapType() {\n      if (this.isBotGame && this.$store.state.lobby.mapCode) {\n        const mapCode = this.$store.state.lobby.mapCode;\n        if (mapCode === \"SUMMONERS_RIFT\") {\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n        } else if (mapCode === \"TWISTED_TREELINE\") {\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n        } else if (mapCode === \"ARAM\") {\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n        }\n      }\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n      }\n      return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n    },\n    getTeamSize() {\n      if (this.isBotGame && this.$store.state.lobby.teamSize) {\n        return this.$store.state.lobby.teamSize;\n      }\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && (lobbyType.includes(\"SUMMONERS_RIFT\") || lobbyType.includes(\"ARAM\"))) {\n        return \"5x5\";\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return \"3x3\";\n      }\n      return \"5x5\";\n    },\n    getQueueTimer() {\n      let format = \"\";\n      if (this.$store.state.lobbyQueueTime >= 3600) {\n        format = \"HH:mm:ss\";\n      } else {\n        format = \"mm:ss\";\n      }\n      return moment.utc(this.$store.state.lobbyQueueTime * 1000).format(format);\n    },\n    sendLobbyChatMessage() {\n      if (this.isBotGame && !this.isHumanPlayer) {\n        return;\n      }\n      const message = this.$refs.chatInput.value;\n      if (message.trim() == \"\") return;\n      this.$refs.chatInput.value = \"\";\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: message\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$nextTick(() => {\n          if (this.$refs.chatMessages) {\n            this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n          }\n        });\n      });\n    },\n    leaveLobby() {\n      const route = this.$route.name;\n      const router = this.$router;\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        if (route != \"Home\") {\n          router.push(\"/LoggedIn/home\");\n        }\n      });\n    },\n    goBackToModeSelect() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$router.push(\"/LoggedIn/play\");\n    },\n    startQueue() {\n      if (this.inQueue) return;\n      if (this.isBotGame) {\n        if (!this.canStartBotGame) {\n          this.$modal.setter.show({\n            title: this.$translate.text(\"LOBBY_CANNOT_START\"),\n            body: this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS_DETAIL\"),\n            footer: this.$translate.text(\"GENERAL_OK\")\n          });\n          return;\n        }\n        this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {\n          data: {\n            difficulty: this.botDifficulty\n          }\n        }, (response, error) => {\n          if (error) {\n            console.log(\"Flyback error:\");\n            console.log(error);\n            this.$modal.setter.show({\n              title: this.$translate.text(\"LOBBY_START_FAILED\"),\n              body: error.message || this.$translate.text(\"LOBBY_START_FAILED_DESC\"),\n              footer: this.$translate.text(\"GENERAL_OK\")\n            });\n          }\n        });\n        return;\n      }\n      this.$sound.template(\"CORE_QUEUE_START\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_START\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n          if (error && error.message && error.code === 140) {\n            const dodgersRaw = error.message.replace(/[{ }]/g, \"\").split(\",\");\n            let worstDodger = null;\n            dodgersRaw.forEach(dodger => {\n              const timeRaw = dodger.split(\"=\")[1];\n              let splitTime = timeRaw.split(\":\");\n              const time = parseInt(splitTime[0] * 60) + parseInt(splitTime[1]);\n              if (worstDodger == null || worstDodger.secnum < time) {\n                worstDodger = {\n                  name: dodger.split(\"=\")[0],\n                  time: dodger.split(\"=\")[1],\n                  secnum: time\n                };\n              }\n            });\n            this.$modal.setter.show({\n              title: this.$translate.text(\"LOBBY_DODGE_TITLE\"),\n              body: this.$translate.text(\"LOBBY_DODGE_BODY\", {\n                name: worstDodger.name,\n                time: worstDodger.time\n              }),\n              footer: this.$translate.text(\"LOBBY_DODGE_FOOTER\")\n            });\n          } else {\n            this.$modal.setter.show({\n              title: this.$translate.text(\"LOBBY_START_FAILED\"),\n              body: error.message || this.$translate.text(\"LOBBY_START_FAILED_DESC\"),\n              footer: this.$translate.text(\"GENERAL_OK\")\n            });\n          }\n        } else {\n          this.$sound.template(\"CORE_MUSIC_QUEUE\");\n        }\n      });\n      this.$store.dispatch(\"getQueueCount\");\n      this.$store.dispatch(\"getServerCount\");\n    },\n    stopQueue() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$store.dispatch(\"clearLobbyTimers\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_STOP\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$store.dispatch(\"setLobbyQueueState\", false);\n      });\n      this.$sound.stopAllLoops(\"CORE_MUSIC\");\n      this.$store.dispatch(\"getQueueCount\");\n      this.$store.dispatch(\"getServerCount\");\n    },\n    t(key, params) {\n      return this.$translate.text(key, params);\n    },\n    tWithParams(key, params) {\n      return this.$translate.text(key, params);\n    }\n  },\n  beforeMount() {\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\n    this.$store.dispatch(\"changeBackgroundState\", \"LOBBY\");\n  },\n  mounted() {\n    this.$nextTick(() => {\n      if (this.$refs.chatMessages) {\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n      }\n    });\n  },\n  updated() {\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\n      this.lastMessages = this.lobbyChatMessages.length;\n      this.$nextTick(() => {\n        if (this.$refs.chatMessages) {\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n        }\n      });\n    }\n  },\n  created() {\n    this.$store.dispatch(\"getQueueCount\");\n    this.$store.dispatch(\"getServerCount\");\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","moment","components","data","lastMessages","computed","players","state","lobby","members","lobbyChatMessages","lobbyInvites","invited","inQueue","owner","lobbyOwner","queueNumber","lobbyQueueCount","serverCount","isBotGame","botDifficulty","isCustomGame","isCustom","isHumanPlayer","currentUser","user","summonerName","some","member","isAI","humanPlayersCount","filter","length","canStartBotGame","methods","getMaxPlayers","teamSize","getTeamSize","getInviteStatus","status","$translate","text","getBotDifficultyText","difficulties","BEGINNER","INTERMEDIATE","ADVANCED","getBotDifficultyDescription","descriptions","getStartButtonText","getChatPlaceholder","getQueueType","lobbyType","$store","getMapPreview","mapCode","includes","getMapType","getQueueTimer","format","lobbyQueueTime","utc","sendLobbyChatMessage","message","$refs","chatInput","value","trim","$socket","sendLobbyMessage","response","error","console","log","$nextTick","chatMessages","scrollTop","scrollHeight","leaveLobby","route","$route","name","router","$router","push","goBackToModeSelect","$sound","template","startQueue","$modal","setter","show","title","body","footer","difficulty","code","dodgersRaw","replace","split","worstDodger","forEach","dodger","timeRaw","splitTime","time","parseInt","secnum","dispatch","stopQueue","stopAllLoops","t","key","params","tWithParams","beforeMount","mounted","updated","created"],"sources":["src/views/Lobby.vue"],"sourcesContent":["<template>\r\n  <div id=\"Lobby\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players lolblock\">\r\n            <div class=\"head\">\r\n              {{\r\n                tWithParams(\"LOBBY_YOUR_TEAM_QUEUE\", {\r\n                  queueNumber,\r\n                  serverCount\r\n                })\r\n              }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <Player\r\n                v-for=\"(player, index) in players\"\r\n                :key=\"index\"\r\n                :summoner=\"player\"\r\n                :custom=\"isCustomGame\"\r\n                :isBotGame=\"isBotGame\"\r\n                :botDifficulty=\"botDifficulty\"\r\n              />\r\n              <div class=\"actions\">\r\n                <button class=\"cancelBtn\" v-if=\"!inQueue && !isBotGame\" @click=\"leaveLobby\">\r\n                  {{ t(\"LOBBY_CANCEL_BTN\") }}\r\n                </button>\r\n                <button\r\n                  v-if=\"!inQueue && owner && !isBotGame\"\r\n                  class=\"changeBtn\"\r\n                  @click=\"goBackToModeSelect\"\r\n                >\r\n                  {{ t(\"LOBBY_CHANGE_LOBBY_TYPE\") }}\r\n                </button>\r\n\r\n                <button\r\n                  v-if=\"!owner && inQueue\"\r\n                  class=\"startBtn\"\r\n                  @click=\"stopQueue\"\r\n                >\r\n                  {{ t(\"LOBBY_STOP_QUEUE\") }}\r\n                </button>\r\n                <button\r\n                  v-if=\"owner\"\r\n                  class=\"startBtn\"\r\n                  :class=\"{ 'bot-game-btn': isBotGame }\"\r\n                  @click=\"inQueue ? stopQueue() : startQueue()\"\r\n                  :disabled=\"isBotGame && !canStartBotGame\"\r\n                >\r\n                  {{ getStartButtonText() }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"game\">\r\n            <div class=\"map lolblock\">\r\n              <div class=\"head\">\r\n                {{ t(\"LOBBY_MAP_OPTIONS_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <img :src=\"getMapPreview()\" class=\"preview\" alt=\"\" />\r\n                <div class=\"details\">\r\n                  <p>\r\n                    <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_MAP\") }}:</strong>\r\n                    {{ getMapType() }}\r\n                  </p>\r\n                  <p>\r\n                    <strong\r\n                      >{{ t(\"LOBBY_MAP_OPTIONS_LABEL_TEAMSIZE\") }}:</strong\r\n                    >\r\n                    {{ getTeamSize() }}\r\n                  </p>\r\n                  <p v-if=\"!isBotGame\">\r\n                    <strong\r\n                      >{{ t(\"LOBBY_MAP_OPTIONS_LABEL_QUEUETYPE\") }}:</strong\r\n                    >\r\n                    {{ getQueueType() }}\r\n                  </p>\r\n                  <p v-if=\"isBotGame\">\r\n                    <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_DIFFICULTY\") }}:</strong>\r\n                    {{ getBotDifficultyText() }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"invites lolblock\" v-if=\"!isBotGame\">\r\n              <div class=\"head\">\r\n                {{ t(\"LOBBY_INVITES_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <div\r\n                  class=\"invite\"\r\n                  v-for=\"(invite, index) in lobbyInvites\"\r\n                  :key=\"index\"\r\n                >\r\n                  <span>{{ index }}</span>\r\n                  <span :class=\"invite.toLowerCase()\">\r\n                    {{ getInviteStatus(invite) }}\r\n                  </span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"ai-info lolblock\" v-if=\"isBotGame\">\r\n              <div class=\"head\">\r\n                {{ t(\"LOBBY_AI_INFO_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <div class=\"ai-difficulty-info\">\r\n                  <i class=\"fas fa-robot\"></i>\r\n                  <span>{{ getBotDifficultyDescription() }}</span>\r\n                </div>\r\n                <div class=\"ai-teamsize-info\">\r\n                  <i class=\"fas fa-users\"></i>\r\n                  <span>{{ t(\"LOBBY_AI_TEAM_SIZE\") }}: {{ getTeamSize() }}</span>\r\n                </div>\r\n                <div class=\"ai-players-count\">\r\n                  <i class=\"fas fa-user-friends\"></i>\r\n                  <span>{{ t(\"LOBBY_AI_PLAYERS_COUNT\") }}: {{ humanPlayersCount }}/{{ getMaxPlayers() }}</span>\r\n                </div>\r\n                <div class=\"ai-warning\" v-if=\"!canStartBotGame\">\r\n                  <i class=\"fas fa-exclamation-triangle\"></i>\r\n                  <span>{{ t(\"LOBBY_AI_NEED_PLAYERS\") }}</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"chat lolblock\">\r\n          <div class=\"head\">\r\n            {{ t(\"LOBBY_ALLCHAT_TITLE\") }}\r\n          </div>\r\n          <div class=\"inner\">\r\n            <div class=\"chat-messages\" ref=\"chatMessages\">\r\n              <ChatMessage\r\n                v-for=\"(message, index) in lobbyChatMessages\"\r\n                :key=\"index\"\r\n                :message=\"message\"\r\n              />\r\n            </div>\r\n            <div class=\"chat-input\">\r\n              <input\r\n                type=\"text\"\r\n                ref=\"chatInput\"\r\n                v-on:keyup.enter=\"sendLobbyChatMessage\"\r\n                :disabled=\"isBotGame && !isHumanPlayer\"\r\n                :placeholder=\"getChatPlaceholder()\"\r\n              />\r\n              <button @click=\"sendLobbyChatMessage\" :disabled=\"isBotGame && !isHumanPlayer\">\r\n                {{ t(\"LOBBY_ALLCHAT_SEND_BTN\") }}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\nimport moment from \"moment\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    ChatMessage,\r\n    SideBar\r\n  },\r\n  data() {\r\n    return {\r\n      lastMessages: null\r\n    };\r\n  },\r\n  computed: mapState({\r\n    players: state => state.lobby.members,\r\n    lobbyChatMessages: state => state.lobbyChatMessages,\r\n    lobbyInvites: state => state.lobby.invited,\r\n    inQueue: state => state.lobby.inQueue,\r\n    owner: state => state.lobbyOwner,\r\n    queueNumber: state => state.lobbyQueueCount,\r\n    serverCount: state => state.serverCount,\r\n    isBotGame: state => state.lobby.isBotGame || false,\r\n    botDifficulty: state => state.lobby.botDifficulty,\r\n    isCustomGame: state => state.lobby.isCustom || false,\r\n    isHumanPlayer: state => {\r\n      if (!state.lobby.isBotGame) return true;\r\n      const currentUser = state.user.summonerName;\r\n      return state.lobby.members.some(member => \r\n        member.summonerName === currentUser && !member.isAI\r\n      );\r\n    },\r\n    humanPlayersCount: state => {\r\n      if (!state.lobby.isBotGame) return 0;\r\n      return state.lobby.members.filter(member => !member.isAI).length;\r\n    },\r\n    canStartBotGame: state => {\r\n      if (!state.lobby.isBotGame) return true;\r\n      return state.lobby.members.some(member => !member.isAI);\r\n    }\r\n  }),\r\n  methods: {\r\n    getMaxPlayers() {\r\n      const teamSize = this.getTeamSize();\r\n      if (teamSize === \"5x5\") return 5;\r\n      if (teamSize === \"3x3\") return 3;\r\n      return 5;\r\n    },\r\n    \r\n    getInviteStatus(status) {\r\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\r\n    },\r\n    \r\n    getBotDifficultyText() {\r\n      const difficulties = {\r\n        BEGINNER: this.$translate.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\"),\r\n        INTERMEDIATE: this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\"),\r\n        ADVANCED: this.$translate.text(\"PLAY_DATA_DIFFICULTY_ADVANCED\")\r\n      };\r\n      return difficulties[this.botDifficulty] || this.botDifficulty || this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\");\r\n    },\r\n    \r\n    getBotDifficultyDescription() {\r\n      const descriptions = {\r\n        BEGINNER: this.$translate.text(\"LOBBY_AI_DIFFICULTY_BEGINNER_DESC\"),\r\n        INTERMEDIATE: this.$translate.text(\"LOBBY_AI_DIFFICULTY_INTERMEDIATE_DESC\"),\r\n        ADVANCED: this.$translate.text(\"LOBBY_AI_DIFFICULTY_ADVANCED_DESC\")\r\n      };\r\n      return descriptions[this.botDifficulty] || this.$translate.text(\"LOBBY_AI_DEFAULT_DESC\");\r\n    },\r\n    \r\n    getStartButtonText() {\r\n      if (this.isBotGame) {\r\n        if (!this.canStartBotGame) {\r\n          return this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS\");\r\n        }\r\n        return this.inQueue ? this.$translate.text(\"LOBBY_STOP_QUEUE\") : this.$translate.text(\"LOBBY_START_GAME\");\r\n      }\r\n      return this.inQueue ? this.$translate.text(\"LOBBY_STOP_QUEUE\") : this.$translate.text(\"LOBBY_START_QUEUE\");\r\n    },\r\n    \r\n    getChatPlaceholder() {\r\n      if (this.isBotGame && !this.isHumanPlayer) {\r\n        return this.$translate.text(\"LOBBY_AI_CANNOT_CHAT\");\r\n      }\r\n      return this.$translate.text(\"LOBBY_ALLCHAT_PLACEHOLDER\");\r\n    },\r\n    \r\n    getQueueType() {\r\n      if (this.isBotGame) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_BOT\");\r\n      }\r\n      \r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      switch (lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\r\n        default:\r\n          return \"\";\r\n      }\r\n    },\r\n    \r\n    getMapPreview() {\r\n      if (this.isBotGame && this.$store.state.lobby.mapCode) {\r\n        const mapCode = this.$store.state.lobby.mapCode;\r\n        if (mapCode === \"SUMMONERS_RIFT\") {\r\n          return \"static/images/general/sr-preview.png\";\r\n        } else if (mapCode === \"TWISTED_TREELINE\") {\r\n          return \"static/images/general/tt-preview.png\";\r\n        } else if (mapCode === \"ARAM\") {\r\n          return \"static/images/general/ha-preview.png\";\r\n        }\r\n      }\r\n      \r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\r\n        return \"static/images/general/sr-preview.png\";\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return \"static/images/general/tt-preview.png\";\r\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\r\n        return \"static/images/general/ha-preview.png\";\r\n      }\r\n      return \"static/images/general/sr-preview.png\";\r\n    },\r\n    \r\n    getMapType() {\r\n      if (this.isBotGame && this.$store.state.lobby.mapCode) {\r\n        const mapCode = this.$store.state.lobby.mapCode;\r\n        if (mapCode === \"SUMMONERS_RIFT\") {\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n        } else if (mapCode === \"TWISTED_TREELINE\") {\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\r\n        } else if (mapCode === \"ARAM\") {\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\r\n        }\r\n      }\r\n      \r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\r\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\r\n      }\r\n      return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n    },\r\n    \r\n    getTeamSize() {\r\n      if (this.isBotGame && this.$store.state.lobby.teamSize) {\r\n        return this.$store.state.lobby.teamSize;\r\n      }\r\n      \r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && (lobbyType.includes(\"SUMMONERS_RIFT\") || lobbyType.includes(\"ARAM\"))) {\r\n        return \"5x5\";\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return \"3x3\";\r\n      }\r\n      return \"5x5\";\r\n    },\r\n    \r\n    getQueueTimer() {\r\n      let format = \"\";\r\n      if (this.$store.state.lobbyQueueTime >= 3600) {\r\n        format = \"HH:mm:ss\";\r\n      } else {\r\n        format = \"mm:ss\";\r\n      }\r\n      return moment.utc(this.$store.state.lobbyQueueTime * 1000).format(format);\r\n    },\r\n    \r\n    sendLobbyChatMessage() {\r\n      if (this.isBotGame && !this.isHumanPlayer) {\r\n        return;\r\n      }\r\n      const message = this.$refs.chatInput.value;\r\n      if (message.trim() == \"\") return;\r\n      this.$refs.chatInput.value = \"\";\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_CHAT\",\r\n        { data: message },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n          this.$nextTick(() => {\r\n            if (this.$refs.chatMessages) {\r\n              this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n            }\r\n          });\r\n        }\r\n      );\r\n    },\r\n    \r\n    leaveLobby() {\r\n      const route = this.$route.name;\r\n      const router = this.$router;\r\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\r\n        if (error) {\r\n          console.log(\"Flyback error:\");\r\n          console.log(error);\r\n        }\r\n        if (route != \"Home\") {\r\n          router.push(\"/LoggedIn/home\");\r\n        }\r\n      });\r\n    },\r\n    \r\n    goBackToModeSelect() {\r\n      this.$sound.template(\"OVERVIEW_CLICK\");\r\n      this.$router.push(\"/LoggedIn/play\");\r\n    },\r\n    \r\n    startQueue() {\r\n      if (this.inQueue) return;\r\n      \r\n      if (this.isBotGame) {\r\n        if (!this.canStartBotGame) {\r\n          this.$modal.setter.show({\r\n            title: this.$translate.text(\"LOBBY_CANNOT_START\"),\r\n            body: this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS_DETAIL\"),\r\n            footer: this.$translate.text(\"GENERAL_OK\")\r\n          });\r\n          return;\r\n        }\r\n        \r\n        this.$socket.sendLobbyMessage(\r\n          \"LOBBY_START_BOT_GAME\",\r\n          { data: { difficulty: this.botDifficulty } },\r\n          (response, error) => {\r\n            if (error) {\r\n              console.log(\"Flyback error:\");\r\n              console.log(error);\r\n              this.$modal.setter.show({\r\n                title: this.$translate.text(\"LOBBY_START_FAILED\"),\r\n                body: error.message || this.$translate.text(\"LOBBY_START_FAILED_DESC\"),\r\n                footer: this.$translate.text(\"GENERAL_OK\")\r\n              });\r\n            }\r\n          }\r\n        );\r\n        return;\r\n      }\r\n      \r\n      this.$sound.template(\"CORE_QUEUE_START\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_START\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n\r\n            if (error && error.message && error.code === 140) {\r\n              const dodgersRaw = error.message.replace(/[{ }]/g, \"\").split(\",\");\r\n              let worstDodger = null;\r\n              dodgersRaw.forEach(dodger => {\r\n                const timeRaw = dodger.split(\"=\")[1];\r\n                let splitTime = timeRaw.split(\":\");\r\n                const time =\r\n                  parseInt(splitTime[0] * 60) + parseInt(splitTime[1]);\r\n                if (worstDodger == null || worstDodger.secnum < time) {\r\n                  worstDodger = {\r\n                    name: dodger.split(\"=\")[0],\r\n                    time: dodger.split(\"=\")[1],\r\n                    secnum: time\r\n                  };\r\n                }\r\n              });\r\n\r\n              this.$modal.setter.show({\r\n                title: this.$translate.text(\"LOBBY_DODGE_TITLE\"),\r\n                body: this.$translate.text(\"LOBBY_DODGE_BODY\", { name: worstDodger.name, time: worstDodger.time }),\r\n                footer: this.$translate.text(\"LOBBY_DODGE_FOOTER\")\r\n              });\r\n            } else {\r\n              this.$modal.setter.show({\r\n                title: this.$translate.text(\"LOBBY_START_FAILED\"),\r\n                body: error.message || this.$translate.text(\"LOBBY_START_FAILED_DESC\"),\r\n                footer: this.$translate.text(\"GENERAL_OK\")\r\n              });\r\n            }\r\n          } else {\r\n            this.$sound.template(\"CORE_MUSIC_QUEUE\");\r\n          }\r\n        }\r\n      );\r\n\r\n      this.$store.dispatch(\"getQueueCount\");\r\n      this.$store.dispatch(\"getServerCount\");\r\n    },\r\n    \r\n    stopQueue() {\r\n      this.$sound.template(\"OVERVIEW_CLICK\");\r\n      this.$store.dispatch(\"clearLobbyTimers\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_STOP\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n          this.$store.dispatch(\"setLobbyQueueState\", false);\r\n        }\r\n      );\r\n\r\n      this.$sound.stopAllLoops(\"CORE_MUSIC\");\r\n      this.$store.dispatch(\"getQueueCount\");\r\n      this.$store.dispatch(\"getServerCount\");\r\n    },\r\n    \r\n    t(key, params) {\r\n      return this.$translate.text(key, params);\r\n    },\r\n    \r\n    tWithParams(key, params) {\r\n      return this.$translate.text(key, params);\r\n    }\r\n  },\r\n  beforeMount() {\r\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\r\n    this.$store.dispatch(\"changeBackgroundState\", \"LOBBY\");\r\n  },\r\n  mounted() {\r\n    this.$nextTick(() => {\r\n      if (this.$refs.chatMessages) {\r\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n      }\r\n    });\r\n  },\r\n  updated() {\r\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\r\n      this.lastMessages = this.lobbyChatMessages.length;\r\n      this.$nextTick(() => {\r\n        if (this.$refs.chatMessages) {\r\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n        }\r\n      });\r\n    }\r\n  },\r\n  created() {\r\n    this.$store.dispatch(\"getQueueCount\");\r\n    this.$store.dispatch(\"getServerCount\");\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"css\" scoped>\r\n#Lobby 