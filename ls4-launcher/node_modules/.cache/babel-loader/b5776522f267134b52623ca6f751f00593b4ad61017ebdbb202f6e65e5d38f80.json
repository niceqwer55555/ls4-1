{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.for-each.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nimport moment from \"moment\";\nexport default {\n  components: {\n    Player,\n    ChatMessage,\n    SideBar\n  },\n  data() {\n    return {\n      lastMessages: null\n    };\n  },\n  computed: {\n    ...mapState({\n      players: state => state.lobby.members,\n      lobbyChatMessages: state => state.lobbyChatMessages,\n      lobbyInvites: state => state.lobby.invited,\n      inQueue: state => state.lobby.inQueue,\n      owner: state => state.lobbyOwner,\n      queueNumber: state => state.lobbyQueueCount,\n      serverCount: state => state.serverCount\n    }),\n    // === 人机模式增强 ===\n    isBotLobby() {\n      const type = this.$store.state.lobby.lobbyType || \"\";\n      return type.startsWith(\"COOP_\");\n    },\n    botDifficultyText() {\n      const type = this.$store.state.lobby.lobbyType || \"\";\n      if (type.includes(\"BOT_EASY\")) return \"简单\";\n      if (type.includes(\"BOT_HARD\")) return \"困难\";\n      return \"一般\";\n    },\n    botTeammates() {\n      const total = this.$store.state.lobby.lobbyType?.includes(\"TWISTED_TREELINE\") ? 2 : 4;\n      const bots = [];\n      for (let i = 0; i < total; i++) {\n        bots.push({\n          summonerName: `AI_队友${i + 1}`,\n          isBot: true,\n          isOwner: false,\n          level: 30,\n          icon: 1\n        });\n      }\n      return bots;\n    }\n  },\n  methods: {\n    // === 人机直接开始游戏 ===\n    startBotGame() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {}, res => {\n        if (res.success) {\n          this.$router.push(\"/gameLoading\");\n        }\n      });\n    },\n    getInviteStatus(status) {\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\n    },\n    inLobby(invite) {\n      return this.$store.state.lobby.members.filter(member => {\n        return member.summonerName == invite.summonerName;\n      }).length > 0;\n    },\n    getQueueType() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"TWISTED_TREELINE_DRAFT\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\n        case \"COOP_VS_AI_BOT_EASY\":\n        case \"COOP_VS_AI_BOT_NORMAL\":\n        case \"COOP_VS_AI_BOT_HARD\":\n        case \"COOP_ARAM_BLIND\":\n          return \"人机训练\";\n      }\n    },\n    getMapPreview() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"COOP_VS_AI_BOT_EASY\":\n        case \"COOP_VS_AI_BOT_NORMAL\":\n        case \"COOP_VS_AI_BOT_HARD\":\n          return \"static/images/general/sr-preview.png\";\n        case \"TWISTED_TREELINE_DRAFT\":\n        case \"TWISTED_TREELINE_BLIND\":\n        case \"COOP_TT_BOT_EASY\":\n        case \"COOP_TT_BOT_NORMAL\":\n          return \"static/images/general/tt-preview.png\";\n        case \"ARAM_BLIND\":\n        case \"COOP_ARAM_BLIND\":\n          return \"static/images/general/ha-preview.png\";\n      }\n    },\n    getMapType() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"COOP_VS_AI_BOT_EASY\":\n        case \"COOP_VS_AI_BOT_NORMAL\":\n        case \"COOP_VS_AI_BOT_HARD\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n        case \"TWISTED_TREELINE_DRAFT\":\n        case \"TWISTED_TREELINE_BLIND\":\n        case \"COOP_TT_BOT_EASY\":\n        case \"COOP_TT_BOT_NORMAL\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n        case \"ARAM_BLIND\":\n        case \"COOP_ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n      }\n    },\n    getTeamSize() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"ARAM_BLIND\":\n        case \"COOP_VS_AI_BOT_EASY\":\n        case \"COOP_VS_AI_BOT_NORMAL\":\n        case \"COOP_VS_AI_BOT_HARD\":\n        case \"COOP_ARAM_BLIND\":\n          return \"5x5\";\n        case \"TWISTED_TREELINE_DRAFT\":\n        case \"TWISTED_TREELINE_BLIND\":\n        case \"COOP_TT_BOT_EASY\":\n        case \"COOP_TT_BOT_NORMAL\":\n          return \"3x3\";\n      }\n    },\n    getQueueTimer() {\n      let format = \"\";\n      if (this.$store.state.lobbyQueueTime >= 3600) {\n        format = \"HH:mm:ss\";\n      } else {\n        format = \"mm:ss\";\n      }\n      return moment.utc(this.$store.state.lobbyQueueTime * 1000).format(format);\n    },\n    sendLobbyChatMessage() {\n      const message = this.$refs.chatInput.value;\n      if (message.trim() == \"\") return;\n      this.$refs.chatInput.value = \"\";\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: message\n      }, (response, error) => {\n        if (error) console.log(error);\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n      });\n    },\n    leaveLobby() {\n      const route = this.$route.name;\n      const router = this.$router;\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\n        if (error) console.log(error);\n        if (route != \"Home\") router.push(\"/LoggedIn/home\");\n      });\n    },\n    startQueue() {\n      if (this.inQueue) return;\n      this.$sound.template(\"CORE_QUEUE_START\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_START\", {}, (response, error) => {\n        if (error) {\n          console.log(error);\n          if (error && error.message && error.code === 140) {\n            const dodgersRaw = error.message.replace(/[{ }]/g, \"\").split(\",\");\n            let worstDodger = null;\n            dodgersRaw.forEach(dodger => {\n              const timeRaw = dodger.split(\"=\")[1];\n              let splitTime = timeRaw.split(\":\");\n              const time = parseInt(splitTime[0] * 60) + parseInt(splitTime[1]);\n              if (worstDodger == null || worstDodger.secnum < time) {\n                worstDodger = {\n                  name: dodger.split(\"=\")[0],\n                  time: timeRaw,\n                  secnum: time\n                };\n              }\n            });\n            this.$modal.setter.show({\n              title: \"Somebody in your team dodged!\",\n              body: `<center>${worstDodger.name} dodged and is banned from queueing for ${worstDodger.time}</center><br>`,\n              footer: \"This info panel only shows the highest timer!\"\n            });\n          }\n        } else {\n          this.$sound.template(\"CORE_MUSIC_QUEUE\");\n        }\n      });\n      this.$store.dispatch(\"getQueueCount\");\n      this.$store.dispatch(\"getServerCount\");\n    },\n    stopQueue() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$store.dispatch(\"clearLobbyTimers\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_STOP\", {}, (response, error) => {\n        if (error) console.log(error);\n        this.$store.dispatch(\"setLobbyQueueState\", false);\n      });\n      this.$sound.stopAllLoops(\"CORE_MUSIC\");\n      this.$store.dispatch(\"getQueueCount\");\n      this.$store.dispatch(\"getServerCount\");\n    }\n  },\n  beforeMount() {\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\n    this.$store.dispatch(\"changeBackgroundState\", \"LOBBY\");\n  },\n  updated() {\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\n      this.lastMessages = this.lobbyChatMessages.length;\n      this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n    }\n  },\n  created() {\n    this.$store.dispatch(\"getQueueCount\");\n    this.$store.dispatch(\"getServerCount\");\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","moment","components","data","lastMessages","computed","players","state","lobby","members","lobbyChatMessages","lobbyInvites","invited","inQueue","owner","lobbyOwner","queueNumber","lobbyQueueCount","serverCount","isBotLobby","type","$store","lobbyType","startsWith","botDifficultyText","includes","botTeammates","total","bots","i","push","summonerName","isBot","isOwner","level","icon","methods","startBotGame","$sound","template","$socket","sendLobbyMessage","res","success","$router","getInviteStatus","status","$translate","text","inLobby","invite","filter","member","length","getQueueType","getMapPreview","getMapType","getTeamSize","getQueueTimer","format","lobbyQueueTime","utc","sendLobbyChatMessage","message","$refs","chatInput","value","trim","response","error","console","log","chatMessages","scrollTop","scrollHeight","leaveLobby","route","$route","name","router","startQueue","code","dodgersRaw","replace","split","worstDodger","forEach","dodger","timeRaw","splitTime","time","parseInt","secnum","$modal","setter","show","title","body","footer","dispatch","stopQueue","stopAllLoops","beforeMount","updated","created"],"sources":["src/views/Lobby.vue"],"sourcesContent":["<template>\r\n  <div id=\"Lobby\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players lolblock\">\r\n            <div class=\"head\">\r\n              {{\r\n                tWithParams(\"LOBBY_YOUR_TEAM_QUEUE\", {\r\n                  queueNumber,\r\n                  serverCount\r\n                })\r\n              }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <Player\r\n                v-for=\"(player, index) in players\"\r\n                :key=\"index\"\r\n                :summoner=\"player\"\r\n              />\r\n\r\n              <!-- AI 队友显示（自动填充） -->\r\n              <Player\r\n                v-for=\"(bot, index) in botTeammates\"\r\n                :key=\"`bot_${index}`\"\r\n                :summoner=\"bot\"\r\n              />\r\n\r\n              <div class=\"actions\">\r\n                <button class=\"cancelBtn\" v-if=\"!inQueue\" @click=\"leaveLobby\">\r\n                  {{ t(\"LOBBY_CANCEL_BTN\") }}\r\n                </button>\r\n                <button\r\n                  v-if=\"!inQueue && owner\"\r\n                  class=\"changeBtn\"\r\n                  @click=\"$router.push('/LoggedIn/play')\"\r\n                >\r\n                  {{ t(\"LOBBY_CHANGE_LOBBY_TYPE\") }}\r\n                </button>\r\n\r\n                <!-- 人机模式 → 直接开始游戏（不排队）-->\r\n                <button\r\n                  v-if=\"owner && isBotLobby\"\r\n                  class=\"startBtn\"\r\n                  @click=\"startBotGame\"\r\n                >\r\n                  {{ t(\"LOBBY_START_GAME\") }}\r\n                </button>\r\n\r\n                <button\r\n                  v-if=\"!owner && inQueue\"\r\n                  class=\"startBtn\"\r\n                  @click=\"stopQueue\"\r\n                >\r\n                  {{ t(\"LOBBY_STOP_QUEUE\") }}\r\n                </button>\r\n                <button\r\n                  v-else-if=\"owner && !isBotLobby\"\r\n                  class=\"startBtn\"\r\n                  @click=\"inQueue ? stopQueue() : startQueue()\"\r\n                >\r\n                  {{ inQueue ? t(\"LOBBY_STOP_QUEUE\") : t(\"LOBBY_START_QUEUE\") }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"game\">\r\n            <div class=\"map lolblock\">\r\n              <div class=\"head\">\r\n                {{ t(\"LOBBY_MAP_OPTIONS_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <img :src=\"getMapPreview()\" class=\"preview\" alt=\"\" />\r\n                <div class=\"details\">\r\n                  <p>\r\n                    <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_MAP\") }}:</strong>\r\n                    {{ getMapType() }}\r\n                  </p>\r\n                  <p>\r\n                    <strong\r\n                      >{{ t(\"LOBBY_MAP_OPTIONS_LABEL_TEAMSIZE\") }}:</strong\r\n                    >\r\n                    {{ getTeamSize() }}\r\n                  </p>\r\n                  <p>\r\n                    <strong\r\n                      >{{ t(\"LOBBY_MAP_OPTIONS_LABEL_QUEUETYPE\") }}:</strong\r\n                    >\r\n                    {{ getQueueType() }}\r\n                  </p>\r\n                  <!-- 人机难度显示 -->\r\n                  <p v-if=\"isBotLobby\">\r\n                    <strong>难度:</strong>\r\n                    {{ botDifficultyText }}\r\n                  </p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"invites lolblock\">\r\n              <div class=\"head\">\r\n                {{ t(\"LOBBY_INVITES_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <div\r\n                  class=\"invite\"\r\n                  v-for=\"(invite, index) in lobbyInvites\"\r\n                  :key=\"index\"\r\n                >\r\n                  <span>{{ index }}</span>\r\n                  <span :class=\"invite.toLowerCase()\">\r\n                    {{ getInviteStatus(invite) }}\r\n                  </span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"chat lolblock\">\r\n          <div class=\"head\">\r\n            {{ t(\"LOBBY_ALLCHAT_TITLE\") }}\r\n          </div>\r\n          <div class=\"inner\">\r\n            <div class=\"chat-messages\" ref=\"chatMessages\">\r\n              <ChatMessage\r\n                v-for=\"(message, index) in lobbyChatMessages\"\r\n                :key=\"index\"\r\n                :message=\"message\"\r\n              />\r\n            </div>\r\n            <div class=\"chat-input\">\r\n              <input\r\n                type=\"text\"\r\n                ref=\"chatInput\"\r\n                v-on:keyup.enter=\"sendLobbyChatMessage\"\r\n              />\r\n              <button @click=\"sendLobbyChatMessage\">\r\n                {{ t(\"LOBBY_ALLCHAT_SEND_BTN\") }}\r\n              </button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\nimport moment from \"moment\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    ChatMessage,\r\n    SideBar\r\n  },\r\n  data() {\r\n    return {\r\n      lastMessages: null\r\n    };\r\n  },\r\n  computed: {\r\n    ...mapState({\r\n      players: state => state.lobby.members,\r\n      lobbyChatMessages: state => state.lobbyChatMessages,\r\n      lobbyInvites: state => state.lobby.invited,\r\n      inQueue: state => state.lobby.inQueue,\r\n      owner: state => state.lobbyOwner,\r\n      queueNumber: state => state.lobbyQueueCount,\r\n      serverCount: state => state.serverCount\r\n    }),\r\n\r\n    // === 人机模式增强 ===\r\n    isBotLobby() {\r\n      const type = this.$store.state.lobby.lobbyType || \"\";\r\n      return type.startsWith(\"COOP_\");\r\n    },\r\n    botDifficultyText() {\r\n      const type = this.$store.state.lobby.lobbyType || \"\";\r\n      if (type.includes(\"BOT_EASY\")) return \"简单\";\r\n      if (type.includes(\"BOT_HARD\")) return \"困难\";\r\n      return \"一般\";\r\n    },\r\n    botTeammates() {\r\n      const total = this.$store.state.lobby.lobbyType?.includes(\"TWISTED_TREELINE\") ? 2 : 4;\r\n      const bots = [];\r\n      for (let i = 0; i < total; i++) {\r\n        bots.push({\r\n          summonerName: `AI_队友${i + 1}`,\r\n          isBot: true,\r\n          isOwner: false,\r\n          level: 30,\r\n          icon: 1\r\n        });\r\n      }\r\n      return bots;\r\n    }\r\n  },\r\n  methods: {\r\n    // === 人机直接开始游戏 ===\r\n    startBotGame() {\r\n      this.$sound.template(\"OVERVIEW_CLICK\");\r\n      this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {}, (res) => {\r\n        if (res.success) {\r\n          this.$router.push(\"/gameLoading\");\r\n        }\r\n      });\r\n    },\r\n\r\n    getInviteStatus(status) {\r\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\r\n    },\r\n    inLobby(invite) {\r\n      return (\r\n        this.$store.state.lobby.members.filter(member => {\r\n          return member.summonerName == invite.summonerName;\r\n        }).length > 0\r\n      );\r\n    },\r\n    getQueueType() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\r\n        case \"COOP_VS_AI_BOT_EASY\":\r\n        case \"COOP_VS_AI_BOT_NORMAL\":\r\n        case \"COOP_VS_AI_BOT_HARD\":\r\n        case \"COOP_ARAM_BLIND\":\r\n          return \"人机训练\";\r\n      }\r\n    },\r\n    getMapPreview() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"COOP_VS_AI_BOT_EASY\":\r\n        case \"COOP_VS_AI_BOT_NORMAL\":\r\n        case \"COOP_VS_AI_BOT_HARD\":\r\n          return \"static/images/general/sr-preview.png\";\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n        case \"COOP_TT_BOT_EASY\":\r\n        case \"COOP_TT_BOT_NORMAL\":\r\n          return \"static/images/general/tt-preview.png\";\r\n        case \"ARAM_BLIND\":\r\n        case \"COOP_ARAM_BLIND\":\r\n          return \"static/images/general/ha-preview.png\";\r\n      }\r\n    },\r\n    getMapType() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"COOP_VS_AI_BOT_EASY\":\r\n        case \"COOP_VS_AI_BOT_NORMAL\":\r\n        case \"COOP_VS_AI_BOT_HARD\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n        case \"COOP_TT_BOT_EASY\":\r\n        case \"COOP_TT_BOT_NORMAL\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\r\n        case \"ARAM_BLIND\":\r\n        case \"COOP_ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\r\n      }\r\n    },\r\n    getTeamSize() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"ARAM_BLIND\":\r\n        case \"COOP_VS_AI_BOT_EASY\":\r\n        case \"COOP_VS_AI_BOT_NORMAL\":\r\n        case \"COOP_VS_AI_BOT_HARD\":\r\n        case \"COOP_ARAM_BLIND\":\r\n          return \"5x5\";\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n        case \"COOP_TT_BOT_EASY\":\r\n        case \"COOP_TT_BOT_NORMAL\":\r\n          return \"3x3\";\r\n      }\r\n    },\r\n    getQueueTimer() {\r\n      let format = \"\";\r\n      if (this.$store.state.lobbyQueueTime >= 3600) {\r\n        format = \"HH:mm:ss\";\r\n      } else {\r\n        format = \"mm:ss\";\r\n      }\r\n      return moment.utc(this.$store.state.lobbyQueueTime * 1000).format(format);\r\n    },\r\n    sendLobbyChatMessage() {\r\n      const message = this.$refs.chatInput.value;\r\n      if (message.trim() == \"\") return;\r\n      this.$refs.chatInput.value = \"\";\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_CHAT\",\r\n        { data: message },\r\n        (response, error) => {\r\n          if (error) console.log(error);\r\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n        }\r\n      );\r\n    },\r\n    leaveLobby() {\r\n      const route = this.$route.name;\r\n      const router = this.$router;\r\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\r\n        if (error) console.log(error);\r\n        if (route != \"Home\") router.push(\"/LoggedIn/home\");\r\n      });\r\n    },\r\n    startQueue() {\r\n      if (this.inQueue) return;\r\n      this.$sound.template(\"CORE_QUEUE_START\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_START\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(error);\r\n            if (error && error.message && error.code === 140) {\r\n              const dodgersRaw = error.message.replace(/[{ }]/g, \"\").split(\",\");\r\n              let worstDodger = null;\r\n              dodgersRaw.forEach(dodger => {\r\n                const timeRaw = dodger.split(\"=\")[1];\r\n                let splitTime = timeRaw.split(\":\");\r\n                const time = parseInt(splitTime[0] * 60) + parseInt(splitTime[1]);\r\n                i