{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport { ipcRenderer } from \"electron\";\nimport { mapState } from \"vuex\";\nexport default {\n  data() {\n    return {\n      ping: \"...\",\n      selectedMode: null,\n      selectedGameMode: null,\n      selectedGameMap: null,\n      selectedGameType: null,\n      isCreatingLobby: false,\n      modes: [{\n        name: this.$translate.text(\"PLAY_DATA_LOBBY_PVP\"),\n        custom: false,\n        disabled: false,\n        selected: false,\n        description: this.$translate.text(\"PLAY_MODE_PVP_DESCRIPTION\"),\n        gamemodes: [{\n          id: 1,\n          name: this.$translate.text(\"PLAY_DATA_MODE_CLASSIC\"),\n          selected: false,\n          bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\n          description: this.$translate.text(\"PLAY_MODE_CLASSIC_DESCRIPTION\"),\n          maps: [{\n            id: 1,\n            name: this.$translate.text(\"PLAY_DATA_MAP_SR\"),\n            sub: \"5x5\",\n            code: \"SUMMONERS_RIFT\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_BLIND\"),\n              selected: false,\n              code: \"BLIND\"\n            }, {\n              id: 2,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_DRAFT\"),\n              selected: false,\n              code: \"DRAFT\"\n            }]\n          }, {\n            id: 2,\n            name: this.$translate.text(\"PLAY_DATA_MAP_TT\"),\n            sub: \"3x3\",\n            code: \"TWISTED_TREELINE\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_BLIND\"),\n              selected: false,\n              code: \"BLIND\"\n            }, {\n              id: 2,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_DRAFT\"),\n              selected: false,\n              code: \"DRAFT\"\n            }]\n          }]\n        }, {\n          id: 2,\n          name: this.$translate.text(\"PLAY_DATA_MODE_ARAM\"),\n          selected: false,\n          bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\n          description: this.$translate.text(\"PLAY_MODE_ARAM_DESCRIPTION\"),\n          maps: [{\n            id: 1,\n            name: this.$translate.text(\"PLAY_DATA_MAP_HA\"),\n            sub: \"5x5\",\n            code: \"ARAM\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_RANDOM\"),\n              selected: false,\n              code: \"BLIND\"\n            }]\n          }]\n        }]\n      }, {\n        name: this.$translate.text(\"PLAY_DATA_LOBBY_COOPVSAI\"),\n        custom: false,\n        disabled: false,\n        // 启用人机模式\n        selected: false,\n        description: this.$translate.text(\"PLAY_MODE_COOP_DESCRIPTION\"),\n        gamemodes: [{\n          id: 1,\n          name: this.$translate.text(\"PLAY_DATA_MODE_CLASSIC\"),\n          selected: false,\n          bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\n          description: this.$translate.text(\"PLAY_MODE_CLASSIC_COOP_DESCRIPTION\"),\n          maps: [{\n            id: 1,\n            name: this.$translate.text(\"PLAY_DATA_MAP_SR\"),\n            sub: \"5x5\",\n            code: \"SUMMONERS_RIFT\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_COOP\"),\n              sub: this.$translate.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\"),\n              selected: false,\n              code: \"COOP_BEGINNER\",\n              difficulty: \"BEGINNER\"\n            }, {\n              id: 2,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_COOP\"),\n              sub: this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\"),\n              selected: false,\n              code: \"COOP_INTERMEDIATE\",\n              difficulty: \"INTERMEDIATE\"\n            }]\n          }]\n        }, {\n          id: 2,\n          name: this.$translate.text(\"PLAY_DATA_MODE_ARAM\"),\n          selected: false,\n          bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\n          description: this.$translate.text(\"PLAY_MODE_ARAM_COOP_DESCRIPTION\"),\n          maps: [{\n            id: 1,\n            name: this.$translate.text(\"PLAY_DATA_MAP_HA\"),\n            sub: \"5x5\",\n            code: \"ARAM\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_COOP\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_RANDOM\"),\n              selected: false,\n              code: \"ARAM_COOP\",\n              difficulty: \"NORMAL\"\n            }]\n          }]\n        }]\n      }, {\n        name: this.$translate.text(\"PLAY_DATA_LOBBY_CUSTOM\"),\n        custom: true,\n        disabled: false,\n        selected: false,\n        description: this.$translate.text(\"PLAY_MODE_CUSTOM_DESCRIPTION\"),\n        gamemodes: [{\n          id: 1,\n          name: this.$translate.text(\"PLAY_DATA_MODE_CLASSIC\"),\n          selected: false,\n          bgimage: \"static/images/gamemodes/gamemode_bg_classic_custom.jpg\",\n          description: this.$translate.text(\"PLAY_MODE_CUSTOM_CLASSIC_DESCRIPTION\"),\n          maps: [{\n            id: 1,\n            name: this.$translate.text(\"PLAY_DATA_MAP_SR\"),\n            sub: \"5x5\",\n            code: \"SUMMONERS_RIFT\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_BLIND\"),\n              selected: false,\n              code: \"BLIND\"\n            }, {\n              id: 2,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_DRAFT\"),\n              selected: false,\n              code: \"DRAFT\"\n            }]\n          }, {\n            id: 2,\n            name: this.$translate.text(\"PLAY_DATA_MAP_TT\"),\n            sub: \"3x3\",\n            code: \"TWISTED_TREELINE\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_BLIND\"),\n              selected: false,\n              code: \"BLIND\"\n            }, {\n              id: 2,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_DRAFT\"),\n              selected: false,\n              code: \"DRAFT\"\n            }]\n          }]\n        }, {\n          id: 2,\n          name: this.$translate.text(\"PLAY_DATA_MODE_ARAM\"),\n          selected: false,\n          bgimage: \"static/images/gamemodes/gamemode_bg_classic_custom.jpg\",\n          description: this.$translate.text(\"PLAY_MODE_CUSTOM_ARAM_DESCRIPTION\"),\n          maps: [{\n            id: 1,\n            name: this.$translate.text(\"PLAY_DATA_MAP_HA\"),\n            sub: \"5x5\",\n            code: \"ARAM\",\n            selected: false,\n            types: [{\n              id: 1,\n              name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\n              sub: this.$translate.text(\"PLAY_DATA_PICK_RANDOM\"),\n              selected: false,\n              code: \"BLIND\"\n            }]\n          }]\n        }]\n      }, {\n        name: this.$translate.text(\"PLAY_DATA_LOBBY_TUTORIAL\"),\n        custom: false,\n        disabled: true,\n        selected: false,\n        description: this.$translate.text(\"PLAY_MODE_TUTORIAL_DESCRIPTION\"),\n        gamemodes: []\n      }]\n    };\n  },\n  created() {\n    const host = this.$store.state.config.api.host.includes(\"//\") ? this.$store.state.config.api.host.split(\"//\")[1] : null;\n    if (host !== null) {\n      ipcRenderer.invoke(\"ping\", host).then(result => {\n        if (result.alive) {\n          this.ping = Math.round(result.avg) + \" ms\";\n        } else {\n          this.ping = \"Unknown\";\n        }\n      });\n    }\n  },\n  computed: mapState({\n    inLobby: state => {\n      return state.lobby.lobbyType;\n    }\n  }),\n  methods: {\n    goHome() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$router.push(\"/LoggedIn/home\");\n    },\n    createLobby() {\n      if (this.isCreatingLobby) return;\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.isCreatingLobby = true;\n      const custom = this.selectedMode.custom;\n      const isCoop = this.selectedMode.name === this.$translate.text(\"PLAY_DATA_LOBBY_COOPVSAI\");\n      const lobbyType = `${this.selectedGameMap.code}_${this.selectedGameType.code}`;\n      const router = this.$router;\n\n      // 构建请求数据\n      const requestData = {\n        lobbyType: lobbyType,\n        isCustom: custom,\n        isCoop: isCoop\n      };\n\n      // 添加人机难度信息\n      if (isCoop && this.selectedGameType.difficulty) {\n        requestData.difficulty = this.selectedGameType.difficulty;\n      }\n      const handleResponse = (response, error) => {\n        this.isCreatingLobby = false;\n        if (error) {\n          console.log(\"Flyback error:\", error);\n          // 显示错误提示\n          if (this.$toast) {\n            this.$toast.error(this.$translate.text(\"PLAY_ERROR_CREATE_LOBBY\"));\n          } else {\n            alert(this.$translate.text(\"PLAY_ERROR_CREATE_LOBBY\"));\n          }\n          return;\n        }\n\n        // 导航到对应页面\n        if (custom && this.$route.name !== \"LobbyCustom\") {\n          router.push(\"/lobbyCustom\");\n        } else if (!custom && this.$route.name !== \"Lobby\") {\n          router.push(\"/lobby\");\n        }\n      };\n      if (this.$store.state.lobby.owner) {\n        this.$socket.sendLobbyMessage(\"LOBBY_CHANGE_TYPE\", {\n          data: requestData\n        }, handleResponse);\n      } else {\n        this.$socket.sendSystemMessage(\"LOBBY_CREATE\", {\n          data: requestData\n        }, handleResponse);\n      }\n    },\n    getModeInfoStyles() {\n      return `background-image: url('${this.selectedGameMode.bgimage}')`;\n    },\n    selectMode(mode) {\n      if (mode.disabled) return;\n      if (this.selectedMode == mode) return;\n      this.selectedMode = mode;\n      this.selectedGameMode = this.selectedMode.gamemodes[0];\n      if (this.selectedGameMode) {\n        this.selectedGameMap = this.selectedGameMode.maps[0];\n        if (this.selectedGameMap) {\n          this.selectedGameType = this.selectedGameMap.types[0];\n        }\n      }\n      this.$sound.template(\"CORE_CLICK\");\n    },\n    selectGameMode(gamemode) {\n      if (this.selectedGameMode == gamemode) return;\n      this.selectedGameMode = gamemode;\n      this.selectedGameMap = this.selectedGameMode.maps[0];\n      if (this.selectedGameMap) {\n        this.selectedGameType = this.selectedGameMap.types[0];\n      }\n      this.$sound.template(\"CORE_CLICK\");\n    },\n    selectGameMap(map) {\n      if (this.selectedGameMap == map) return;\n      this.selectedGameMap = map;\n      this.selectedGameType = this.selectedGameMap.types[0];\n      this.$sound.template(\"CORE_CLICK\");\n    },\n    selectGameType(type) {\n      if (this.selectedGameType == type) return;\n      this.selectedGameType = type;\n      this.$sound.template(\"CORE_CLICK\");\n    }\n  },\n  beforeMount() {\n    // 确定默认选中的模式\n    let defaultModeIndex = 0;\n    if (this.$store.state.lobby) {\n      if (this.$store.state.lobby.isCustom) {\n        defaultModeIndex = 2; // Custom模式索引\n      } else if (this.$store.state.lobby.isCoop) {\n        defaultModeIndex = 1; // 人机模式索引\n      }\n    }\n    this.selectedMode = this.modes[defaultModeIndex];\n    if (this.selectedMode && this.selectedMode.gamemodes && this.selectedMode.gamemodes.length > 0) {\n      this.selectedGameMode = this.selectedMode.gamemodes[0];\n      if (this.selectedGameMode && this.selectedGameMode.maps && this.selectedGameMode.maps.length > 0) {\n        this.selectedGameMap = this.selectedGameMode.maps[0];\n        if (this.selectedGameMap && this.selectedGameMap.types && this.selectedGameMap.types.length > 0) {\n          this.selectedGameType = this.selectedGameMap.types[0];\n        }\n      }\n    }\n    this.$store.dispatch(\"changeBackgroundState\", \"MODESELECT\");\n  },\n  beforeDestroy() {\n    this.isCreatingLobby = false;\n  }\n};","map":{"version":3,"names":["ipcRenderer","mapState","data","ping","selectedMode","selectedGameMode","selectedGameMap","selectedGameType","isCreatingLobby","modes","name","$translate","text","custom","disabled","selected","description","gamemodes","id","bgimage","maps","sub","code","types","difficulty","created","host","$store","state","config","api","includes","split","invoke","then","result","alive","Math","round","avg","computed","inLobby","lobby","lobbyType","methods","goHome","$sound","template","$router","push","createLobby","isCoop","router","requestData","isCustom","handleResponse","response","error","console","log","$toast","alert","$route","owner","$socket","sendLobbyMessage","sendSystemMessage","getModeInfoStyles","selectMode","mode","selectGameMode","gamemode","selectGameMap","map","selectGameType","type","beforeMount","defaultModeIndex","length","dispatch","beforeDestroy"],"sources":["src/views/LoggedIn/Play.vue"],"sourcesContent":["<template>\r\n  <div class=\"container\">\r\n    <div class=\"pingdisplay\">PING: {{ ping }}</div>\r\n    <div class=\"modeblock\">\r\n      <div class=\"modeselect\">\r\n        <div class=\"modes\">\r\n          <div\r\n            class=\"mode\"\r\n            @click=\"selectMode(mode)\"\r\n            v-for=\"(mode, index) in modes\"\r\n            :key=\"index\"\r\n            :class=\"{\r\n              inactive: mode.disabled,\r\n              selected: mode.name == selectedMode.name\r\n            }\"\r\n          >\r\n            {{ mode.name }}\r\n          </div>\r\n        </div>\r\n        <div class=\"selects\">\r\n          <div class=\"list\">\r\n            <div class=\"head\">\r\n              {{ t(\"PLAY_GAME_MODE\") }}\r\n            </div>\r\n            <div class=\"items\">\r\n              <div\r\n                v-for=\"(gamemode, index) in selectedMode.gamemodes\"\r\n                :key=\"index\"\r\n                :class=\"{\r\n                  subtexted: gamemode.sub != null,\r\n                  selected: gamemode.id == selectedGameMode.id\r\n                }\"\r\n                @click=\"selectGameMode(gamemode)\"\r\n              >\r\n                <span>\r\n                  {{ gamemode.name }}\r\n                </span>\r\n                <span v-if=\"gamemode.sub != null\">\r\n                  {{ gamemode.sub }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"list\">\r\n            <div class=\"head\">\r\n              {{ t(\"PLAY_GAME_MAP\") }}\r\n            </div>\r\n            <div class=\"items\">\r\n              <div\r\n                v-for=\"(map, index) in selectedGameMode.maps\"\r\n                :key=\"index\"\r\n                :class=\"{\r\n                  subtexted: map.sub != null,\r\n                  selected: map.id == selectedGameMap.id\r\n                }\"\r\n                @click=\"selectGameMap(map)\"\r\n              >\r\n                <span>\r\n                  {{ map.name }}\r\n                </span>\r\n                <span v-if=\"map.sub != null\">\r\n                  {{ map.sub }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"list\">\r\n            <div class=\"head\">\r\n              {{ t(\"PLAY_GAME_TYPE\") }}\r\n            </div>\r\n            <div class=\"items\">\r\n              <div\r\n                v-for=\"(type, index) in selectedGameMap.types\"\r\n                :key=\"index\"\r\n                :class=\"{\r\n                  subtexted: type.sub != null,\r\n                  selected: type.id == selectedGameType.id\r\n                }\"\r\n                @click=\"selectGameType(type)\"\r\n              >\r\n                <span>\r\n                  {{ type.name }}\r\n                </span>\r\n                <span v-if=\"type.sub != null\">\r\n                  {{ type.sub }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n      <div class=\"modeinfo\">\r\n        <div class=\"inner\" v-if=\"selectedGameMode\" :style=\"getModeInfoStyles()\">\r\n          <div class=\"data\">\r\n            <div class=\"head\">\r\n              <h2>{{ selectedGameMode.name }}</h2>\r\n              <h3>{{ selectedGameMap.name }}</h3>\r\n              <p>{{ selectedGameType.name }} ({{ selectedGameType.sub }})</p>\r\n            </div>\r\n            <div class=\"description\">\r\n              {{ selectedGameMode.description }}\r\n            </div>\r\n            <button @click=\"createLobby\" class=\"createLobby\" :disabled=\"isCreatingLobby\">\r\n              {{\r\n                isCreatingLobby \r\n                  ? t(\"PLAY_CREATING_LOBBY\") \r\n                  : (inLobby\r\n                    ? t(\"PLAY_CHANGE_LOBBY_TYPE_BTN\")\r\n                    : t(\"PLAY_CREATE_LOBBY_BTN\"))\r\n              }}\r\n            </button>\r\n            <button @click=\"goHome\" class=\"goHome\">\r\n              {{ t(\"PLAY_HOME_BTN\") }}\r\n            </button>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport { ipcRenderer } from \"electron\";\r\nimport { mapState } from \"vuex\";\r\n\r\nexport default {\r\n  data() {\r\n    return {\r\n      ping: \"...\",\r\n      selectedMode: null,\r\n      selectedGameMode: null,\r\n      selectedGameMap: null,\r\n      selectedGameType: null,\r\n      isCreatingLobby: false,\r\n      modes: [\r\n        {\r\n          name: this.$translate.text(\"PLAY_DATA_LOBBY_PVP\"),\r\n          custom: false,\r\n          disabled: false,\r\n          selected: false,\r\n          description: this.$translate.text(\"PLAY_MODE_PVP_DESCRIPTION\"),\r\n          gamemodes: [\r\n            {\r\n              id: 1,\r\n              name: this.$translate.text(\"PLAY_DATA_MODE_CLASSIC\"),\r\n              selected: false,\r\n              bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\r\n              description: this.$translate.text(\"PLAY_MODE_CLASSIC_DESCRIPTION\"),\r\n              maps: [\r\n                {\r\n                  id: 1,\r\n                  name: this.$translate.text(\"PLAY_DATA_MAP_SR\"),\r\n                  sub: \"5x5\",\r\n                  code: \"SUMMONERS_RIFT\",\r\n                  selected: false,\r\n                  types: [\r\n                    {\r\n                      id: 1,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_PICK_BLIND\"),\r\n                      selected: false,\r\n                      code: \"BLIND\"\r\n                    },\r\n                    {\r\n                      id: 2,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_PICK_DRAFT\"),\r\n                      selected: false,\r\n                      code: \"DRAFT\"\r\n                    }\r\n                  ]\r\n                },\r\n                {\r\n                  id: 2,\r\n                  name: this.$translate.text(\"PLAY_DATA_MAP_TT\"),\r\n                  sub: \"3x3\",\r\n                  code: \"TWISTED_TREELINE\",\r\n                  selected: false,\r\n                  types: [\r\n                    {\r\n                      id: 1,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_PICK_BLIND\"),\r\n                      selected: false,\r\n                      code: \"BLIND\"\r\n                    },\r\n                    {\r\n                      id: 2,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_PICK_DRAFT\"),\r\n                      selected: false,\r\n                      code: \"DRAFT\"\r\n                    }\r\n                  ]\r\n                }\r\n              ]\r\n            },\r\n            {\r\n              id: 2,\r\n              name: this.$translate.text(\"PLAY_DATA_MODE_ARAM\"),\r\n              selected: false,\r\n              bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\r\n              description: this.$translate.text(\"PLAY_MODE_ARAM_DESCRIPTION\"),\r\n              maps: [\r\n                {\r\n                  id: 1,\r\n                  name: this.$translate.text(\"PLAY_DATA_MAP_HA\"),\r\n                  sub: \"5x5\",\r\n                  code: \"ARAM\",\r\n                  selected: false,\r\n                  types: [\r\n                    {\r\n                      id: 1,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_PICK_RANDOM\"),\r\n                      selected: false,\r\n                      code: \"BLIND\"\r\n                    }\r\n                  ]\r\n                }\r\n              ]\r\n            }\r\n          ]\r\n        },\r\n        {\r\n          name: this.$translate.text(\"PLAY_DATA_LOBBY_COOPVSAI\"),\r\n          custom: false,\r\n          disabled: false, // 启用人机模式\r\n          selected: false,\r\n          description: this.$translate.text(\"PLAY_MODE_COOP_DESCRIPTION\"),\r\n          gamemodes: [\r\n            {\r\n              id: 1,\r\n              name: this.$translate.text(\"PLAY_DATA_MODE_CLASSIC\"),\r\n              selected: false,\r\n              bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\r\n              description: this.$translate.text(\"PLAY_MODE_CLASSIC_COOP_DESCRIPTION\"),\r\n              maps: [\r\n                {\r\n                  id: 1,\r\n                  name: this.$translate.text(\"PLAY_DATA_MAP_SR\"),\r\n                  sub: \"5x5\",\r\n                  code: \"SUMMONERS_RIFT\",\r\n                  selected: false,\r\n                  types: [\r\n                    {\r\n                      id: 1,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_COOP\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\"),\r\n                      selected: false,\r\n                      code: \"COOP_BEGINNER\",\r\n                      difficulty: \"BEGINNER\"\r\n                    },\r\n                    {\r\n                      id: 2,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_COOP\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\"),\r\n                      selected: false,\r\n                      code: \"COOP_INTERMEDIATE\",\r\n                      difficulty: \"INTERMEDIATE\"\r\n                    }\r\n                  ]\r\n                }\r\n              ]\r\n            },\r\n            {\r\n              id: 2,\r\n              name: this.$translate.text(\"PLAY_DATA_MODE_ARAM\"),\r\n              selected: false,\r\n              bgimage: \"static/images/gamemodes/gamemode_bg_classic.jpg\",\r\n              description: this.$translate.text(\"PLAY_MODE_ARAM_COOP_DESCRIPTION\"),\r\n              maps: [\r\n                {\r\n                  id: 1,\r\n                  name: this.$translate.text(\"PLAY_DATA_MAP_HA\"),\r\n                  sub: \"5x5\",\r\n                  code: \"ARAM\",\r\n                  selected: false,\r\n                  types: [\r\n                    {\r\n                      id: 1,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_COOP\"),\r\n                      sub: this.$translate.text(\"PLAY_DATA_PICK_RANDOM\"),\r\n                      selected: false,\r\n                      code: \"ARAM_COOP\",\r\n                      difficulty: \"NORMAL\"\r\n                    }\r\n                  ]\r\n                }\r\n              ]\r\n            }\r\n          ]\r\n        },\r\n        {\r\n          name: this.$translate.text(\"PLAY_DATA_LOBBY_CUSTOM\"),\r\n          custom: true,\r\n          disabled: false,\r\n          selected: false,\r\n          description: this.$translate.text(\"PLAY_MODE_CUSTOM_DESCRIPTION\"),\r\n          gamemodes: [\r\n            {\r\n              id: 1,\r\n              name: this.$translate.text(\"PLAY_DATA_MODE_CLASSIC\"),\r\n              selected: false,\r\n              bgimage: \"static/images/gamemodes/gamemode_bg_classic_custom.jpg\",\r\n              description: this.$translate.text(\"PLAY_MODE_CUSTOM_CLASSIC_DESCRIPTION\"),\r\n              maps: [\r\n                {\r\n                  id: 1,\r\n                  name: this.$translate.text(\"PLAY_DATA_MAP_SR\"),\r\n                  sub: \"5x5\",\r\n                  code: \"SUMMONERS_RIFT\",\r\n                  selected: false,\r\n                  types: [\r\n                    {\r\n                      id: 1,\r\n                      name: this.$translate.text(\"PLAY_DATA_TYPE_NORMAL\"),\r