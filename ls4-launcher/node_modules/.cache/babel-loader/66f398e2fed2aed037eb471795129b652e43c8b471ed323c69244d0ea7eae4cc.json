{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.find.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nexport default {\n  components: {\n    Player,\n    SideBar,\n    ChatMessage\n  },\n  data() {\n    return {\n      showModal: false,\n      difficulty: \"MEDIUM\",\n      championId: 1,\n      teamId: 100,\n      champions: [{\n        id: 1,\n        name: \"安妮\"\n      }, {\n        id: 6,\n        name: \"盖伦\"\n      }, {\n        id: 7,\n        name: \"艾希\"\n      }, {\n        id: 9,\n        name: \"易大师\"\n      }, {\n        id: 10,\n        name: \"瑞兹\"\n      }],\n      localBots: {\n        100: [],\n        200: []\n      }\n    };\n  },\n  computed: {\n    ...mapState({\n      players: state => state.lobby?.members || [],\n      lobbyChatMessages: state => state.lobbyChatMessages || []\n    })\n  },\n  methods: {\n    openAddBotModal(teamId) {\n      this.teamId = teamId;\n      this.showModal = true;\n    },\n    closeModal() {\n      this.showModal = false;\n    },\n    addBot() {\n      const champion = this.champions.find(x => x.id === this.championId);\n      const bot = {\n        summonerName: `${champion.name}(AI)`,\n        isBot: true,\n        level: 30,\n        icon: 1,\n        championId: this.championId,\n        difficulty: this.difficulty\n      };\n      this.localBots[this.teamId].push(bot);\n      this.closeModal();\n    },\n    startBotGame() {\n      this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {}, () => {\n        this.$router.push(\"/gameLoading\");\n      });\n    },\n    leaveLobby() {\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, () => {\n        this.$router.push(\"/LoggedIn/home\");\n      });\n    },\n    sendChat() {\n      const text = this.$refs.chatInput.value.trim();\n      if (!text) return;\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: text\n      });\n      this.$refs.chatInput.value = \"\";\n    },\n    getMapPreview() {\n      return \"static/images/general/sr-preview.png\";\n    }\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","components","data","showModal","difficulty","championId","teamId","champions","id","name","localBots","computed","players","state","lobby","members","lobbyChatMessages","methods","openAddBotModal","closeModal","addBot","champion","find","x","bot","summonerName","isBot","level","icon","push","startBotGame","$socket","sendLobbyMessage","$router","leaveLobby","sendChat","text","$refs","chatInput","value","trim","getMapPreview"],"sources":["src/views/Lobby.vue"],"sourcesContent":["<template>\r\n  <div id=\"Lobby\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players lolblock\">\r\n            <div class=\"head\">\r\n              游戏大厅\r\n            </div>\r\n            <div class=\"inner\">\r\n              <!-- 玩家列表 -->\r\n              <Player\r\n                v-for=\"(player, index) in players\"\r\n                :key=\"'player_' + index\"\r\n                :summoner=\"player\"\r\n              />\r\n\r\n              <!-- 己方机器人 -->\r\n              <Player\r\n                v-for=\"(bot, index) in localBots[100]\"\r\n                :key=\"'bot_100_' + index\"\r\n                :summoner=\"bot\"\r\n                :is-bot=\"true\"\r\n              />\r\n\r\n              <!-- 强制显示：添加己方机器人 -->\r\n              <div class=\"bot-action-row\">\r\n                <button class=\"btn-add-bot\" @click=\"openAddBotModal(100)\">\r\n                  ➕ 添加己方机器人\r\n                </button>\r\n              </div>\r\n\r\n              <!-- 敌方队伍 -->\r\n              <div class=\"enemy-team-section\">\r\n                <div class=\"section-title\">敌方队伍</div>\r\n                <Player\r\n                  v-for=\"(bot, index) in localBots[200]\"\r\n                  :key=\"'bot_200_' + index\"\r\n                  :summoner=\"bot\"\r\n                  :is-bot=\"true\"\r\n                />\r\n\r\n                <!-- 强制显示：添加敌方机器人 -->\r\n                <div class=\"bot-action-row\">\r\n                  <button class=\"btn-add-bot\" @click=\"openAddBotModal(200)\">\r\n                    ➕ 添加敌方机器人\r\n                  </button>\r\n                </div>\r\n              </div>\r\n\r\n              <!-- 底部按钮 -->\r\n              <div class=\"action-bar\">\r\n                <button class=\"btn-default\" @click=\"leaveLobby\">离开大厅</button>\r\n                <button class=\"btn-primary\" @click=\"startBotGame\">开始游戏</button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n\r\n          <div class=\"game-info\">\r\n            <div class=\"map lolblock\">\r\n              <div class=\"head\">地图信息</div>\r\n              <div class=\"inner\">\r\n                <img :src=\"getMapPreview()\" class=\"map-img\" alt=\"\" />\r\n                <div class=\"details\">\r\n                  <p>模式：人机对战</p>\r\n                  <p>地图：召唤师峡谷</p>\r\n                </div>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n\r\n        <div class=\"chat lolblock\">\r\n          <div class=\"head\">聊天</div>\r\n          <div class=\"inner\">\r\n            <div class=\"chat-messages\" ref=\"chatMessages\">\r\n              <ChatMessage\r\n                v-for=\"(msg, i) in lobbyChatMessages\"\r\n                :key=\"i\"\r\n                :message=\"msg\"\r\n              />\r\n            </div>\r\n            <div class=\"chat-input\">\r\n              <input type=\"text\" ref=\"chatInput\" @keyup.enter=\"sendChat\" />\r\n              <button @click=\"sendChat\">发送</button>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n\r\n    <!-- 添加机器人弹窗（永远置顶） -->\r\n    <div class=\"bot-modal\" v-if=\"showModal\">\r\n      <div class=\"modal-window\">\r\n        <div class=\"modal-header\">\r\n          <h3>添加机器人</h3>\r\n          <button class=\"close\" @click=\"closeModal\">×</button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <label>难度</label>\r\n          <select v-model=\"difficulty\">\r\n            <option value=\"EASY\">简单</option>\r\n            <option value=\"MEDIUM\">一般</option>\r\n            <option value=\"HARD\">困难</option>\r\n          </select>\r\n\r\n          <label>英雄</label>\r\n          <select v-model=\"championId\">\r\n            <option v-for=\"c in champions\" :key=\"c.id\" :value=\"c.id\">\r\n              {{ c.name }}\r\n            </option>\r\n          </select>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button class=\"confirm\" @click=\"addBot\">确认添加</button>\r\n          <button class=\"cancel\" @click=\"closeModal\">取消</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    SideBar,\r\n    ChatMessage,\r\n  },\r\n  data() {\r\n    return {\r\n      showModal: false,\r\n      difficulty: \"MEDIUM\",\r\n      championId: 1,\r\n      teamId: 100,\r\n      champions: [\r\n        { id: 1, name: \"安妮\" },\r\n        { id: 6, name: \"盖伦\" },\r\n        { id: 7, name: \"艾希\" },\r\n        { id: 9, name: \"易大师\" },\r\n        { id: 10, name: \"瑞兹\" },\r\n      ],\r\n      localBots: {\r\n        100: [],\r\n        200: [],\r\n      },\r\n    };\r\n  },\r\n  computed: {\r\n    ...mapState({\r\n      players: (state) => state.lobby?.members || [],\r\n      lobbyChatMessages: (state) => state.lobbyChatMessages || [],\r\n    }),\r\n  },\r\n  methods: {\r\n    openAddBotModal(teamId) {\r\n      this.teamId = teamId;\r\n      this.showModal = true;\r\n    },\r\n    closeModal() {\r\n      this.showModal = false;\r\n    },\r\n    addBot() {\r\n      const champion = this.champions.find((x) => x.id === this.championId);\r\n      const bot = {\r\n        summonerName: `${champion.name}(AI)`,\r\n        isBot: true,\r\n        level: 30,\r\n        icon: 1,\r\n        championId: this.championId,\r\n        difficulty: this.difficulty,\r\n      };\r\n      this.localBots[this.teamId].push(bot);\r\n      this.closeModal();\r\n    },\r\n    startBotGame() {\r\n      this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {}, () => {\r\n        this.$router.push(\"/gameLoading\");\r\n      });\r\n    },\r\n    leaveLobby() {\r\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, () => {\r\n        this.$router.push(\"/LoggedIn/home\");\r\n      });\r\n    },\r\n    sendChat() {\r\n      const text = this.$refs.chatInput.value.trim();\r\n      if (!text) return;\r\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", { data: text });\r\n      this.$refs.chatInput.value = \"\";\r\n    },\r\n    getMapPreview() {\r\n      return \"static/images/general/sr-preview.png\";\r\n    },\r\n  },\r\n};\r\n</script>\r\n\r\n<style scoped>\r\n#PvpLobby,\r\n#Lobby {\r\n  width: 100%;\r\n  height: calc(100% - 80px);\r\n  display: flex;\r\n  padding-top: 20px;\r\n}\r\n\r\n.content {\r\n  width: 100%;\r\n  display: flex;\r\n  justify-content: center;\r\n}\r\n\r\n.mainblock {\r\n  width: 90%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  gap: 10px;\r\n}\r\n\r\n.lobby {\r\n  display: flex;\r\n  gap: 12px;\r\n}\r\n\r\n.players {\r\n  flex: 2;\r\n}\r\n\r\n.game-info {\r\n  flex: 1;\r\n}\r\n\r\n.lolblock {\r\n  background: rgba(0, 0, 0, 0.4);\r\n  border: 1px solid #4a5568;\r\n  border-radius: 6px;\r\n  overflow: hidden;\r\n  color: white;\r\n}\r\n\r\n.lolblock .head {\r\n  background: #1a2c42;\r\n  padding: 8px 10px;\r\n  font-weight: bold;\r\n}\r\n\r\n.lolblock .inner {\r\n  padding: 10px;\r\n  height: 100%;\r\n}\r\n\r\n.bot-action-row {\r\n  margin: 8px 0;\r\n  text-align: center;\r\n}\r\n\r\n.btn-add-bot {\r\n  background: #2563eb;\r\n  color: white;\r\n  border: none;\r\n  padding: 8px 16px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n  font-size: 14px;\r\n}\r\n\r\n.btn-add-bot:hover {\r\n  background: #3b82f6;\r\n}\r\n\r\n.enemy-team-section {\r\n  margin-top: 16px;\r\n  padding-top: 12px;\r\n  border-top: 1px solid #4a5568;\r\n}\r\n\r\n.section-title {\r\n  font-weight: bold;\r\n  margin-bottom: 8px;\r\n  text-align: center;\r\n}\r\n\r\n.action-bar {\r\n  position: absolute;\r\n  bottom: 10px;\r\n  left: 10px;\r\n  right: 10px;\r\n  display: flex;\r\n  justify-content: space-between;\r\n}\r\n\r\n.btn-default {\r\n  background: #4b5563;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 12px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n\r\n.btn-primary {\r\n  background: #16a34a;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 16px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n\r\n.map-img {\r\n  width: 100%;\r\n  height: 120px;\r\n  object-fit: cover;\r\n  border-radius: 4px;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.chat {\r\n  height: 220px;\r\n}\r\n\r\n.chat-messages {\r\n  height: 150px;\r\n  overflow-y: auto;\r\n  margin-bottom: 8px;\r\n}\r\n\r\n.chat-input {\r\n  display: flex;\r\n  gap: 6px;\r\n}\r\n\r\n.chat-input input {\r\n  flex: 1;\r\n  padding: 6px;\r\n  background: #1f2937;\r\n  color: white;\r\n  border: 1px solid #4b5563;\r\n  border-radius: 4px;\r\n}\r\n\r\n.chat-input button {\r\n  background: #2563eb;\r\n  color: white;\r\n  border: none;\r\n  padding: 0 10px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n\r\n/* 弹窗 */\r\n.bot-modal {\r\n  position: fixed;\r\n  top: 0;\r\n  left: 0;\r\n  width: 100%;\r\n  height: 100%;\r\n  background: rgba(0, 0, 0, 0.7);\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  z-index: 99999;\r\n}\r\n\r\n.modal-window {\r\n  background: #111827;\r\n  border: 2px solid #3b82f6;\r\n  border-radius: 8px;\r\n  width: 360px;\r\n  color: white;\r\n  overflow: hidden;\r\n}\r\n\r\n.modal-header {\r\n  padding: 12px;\r\n  background: #1e40af;\r\n  display: flex;\r\n  justify-content: space-between;\r\n  align-items: center;\r\n}\r\n\r\n.modal-header h3 {\r\n  margin: 0;\r\n}\r\n\r\n.close {\r\n  background: none;\r\n  border: none;\r\n  color: white;\r\n  font-size: 20px;\r\n  cursor: pointer;\r\n}\r\n\r\n.modal-body {\r\n  padding: 16px;\r\n}\r\n\r\n.modal-body label {\r\n  display: block;\r\n  margin-top: 10px;\r\n  margin-bottom: 4px;\r\n}\r\n\r\n.modal-body select {\r\n  width: 100%;\r\n  padding: 6px;\r\n  background: #1f2937;\r\n  color: white;\r\n  border: 1px solid #4b5563;\r\n  border-radius: 4px;\r\n}\r\n\r\n.modal-footer {\r\n  padding: 12px;\r\n  background: #1f2937;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n  gap: 10px;\r\n}\r\n\r\n.confirm {\r\n  background: #16a34a;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 14px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n\r\n.cancel {\r\n  background: #4b5563;\r\n  color: white;\r\n  border: none;\r\n  padding: 6px 14px;\r\n  border-radius: 4px;\r\n  cursor: pointer;\r\n}\r\n</style>"],"mappings":";;;AA4HA,OAAAA,MAAA;AACA,OAAAC,OAAA;AACA,OAAAC,WAAA;AACA,SAAAC,QAAA;AAEA;EACAC,UAAA;IACAJ,MAAA;IACAC,OAAA;IACAC;EACA;EACAG,KAAA;IACA;MACAC,SAAA;MACAC,UAAA;MACAC,UAAA;MACAC,MAAA;MACAC,SAAA,GACA;QAAAC,EAAA;QAAAC,IAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,IAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,IAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,IAAA;MAAA,GACA;QAAAD,EAAA;QAAAC,IAAA;MAAA,EACA;MACAC,SAAA;QACA;QACA;MACA;IACA;EACA;EACAC,QAAA;IACA,GAAAX,QAAA;MACAY,OAAA,EAAAC,KAAA,IAAAA,KAAA,CAAAC,KAAA,EAAAC,OAAA;MACAC,iBAAA,EAAAH,KAAA,IAAAA,KAAA,CAAAG,iBAAA;IACA;EACA;EACAC,OAAA;IACAC,gBAAAZ,MAAA;MACA,KAAA