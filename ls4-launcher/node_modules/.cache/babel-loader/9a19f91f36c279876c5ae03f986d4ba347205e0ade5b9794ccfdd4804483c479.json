{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nexport default {\n  components: {\n    Player,\n    ChatMessage,\n    SideBar\n  },\n  data() {\n    return {\n      lastMessages: null,\n      queueNumber: \"-\",\n      showBotModal: false,\n      botDifficulty: \"MEDIUM\",\n      selectedChampion: {\n        id: 1,\n        name: \"安妮\"\n      },\n      targetTeam: 1,\n      botTeam1: [],\n      botTeam2: [],\n      championList: [{\n        id: 1,\n        name: \"安妮\"\n      }, {\n        id: 6,\n        name: \"盖伦\"\n      }, {\n        id: 7,\n        name: \"艾希\"\n      }, {\n        id: 9,\n        name: \"易大师\"\n      }, {\n        id: 10,\n        name: \"瑞兹\"\n      }]\n    };\n  },\n  computed: {\n    isTeamFull() {\n      if (this.players1 && this.players2) {\n        let user = this.$store.state.user.summonerName;\n        let team1 = this.players1.some(c => c.summonerName == user);\n        let team2 = this.players2.some(c => c.summonerName == user);\n        if (team1 && this.players2.length <= 5) {\n          return false;\n        } else if (team2 && this.players1.length <= 5) {\n          return false;\n        }\n      }\n      return true;\n    },\n    ...mapState({\n      players1: state => state.lobby.members ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM1\") : undefined,\n      players2: state => state.lobby.members ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM2\") : undefined,\n      lobbyChatMessages: state => state.lobbyChatMessages,\n      lobbyInvites: state => state.lobby.invited,\n      inQueue: state => state.lobby.inQueue,\n      owner: state => state.lobbyOwner,\n      serverCount: state => state.serverCount,\n      currentLobbyPlayer: state => {\n        return state.lobby.members.filter(member => {\n          return member.summonerName == state.user.summonerName;\n        })[0];\n      }\n    })\n  },\n  methods: {\n    // 机器人功能\n    addBotToTeam1() {\n      this.targetTeam = 1;\n      this.showBotModal = true;\n    },\n    addBotToTeam2() {\n      this.targetTeam = 2;\n      this.showBotModal = true;\n    },\n    closeBotModal() {\n      this.showBotModal = false;\n    },\n    confirmAddBot() {\n      const bot = {\n        summonerName: this.selectedChampion.name + \" (AI)\",\n        iconId: 1,\n        level: 30,\n        isBot: true,\n        lobbyTeam: this.targetTeam === 1 ? \"TEAM1\" : \"TEAM2\"\n      };\n      if (this.targetTeam === 1) {\n        this.botTeam1.push(bot);\n      } else {\n        this.botTeam2.push(bot);\n      }\n      this.closeBotModal();\n    },\n    canJoinTeam(team) {\n      if (this.players1 && this.players2) {\n        if (team == 2) {\n          return this.players2.length != 5 && this.currentLobbyPlayer.lobbyTeam == \"TEAM1\" && !this.isTeamFull;\n        } else {\n          return this.players1.length != 5 && this.currentLobbyPlayer.lobbyTeam == \"TEAM2\" && !this.isTeamFull;\n        }\n      } else {\n        return false;\n      }\n    },\n    getInviteStatus(status) {\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\n    },\n    inLobby(invite) {\n      return this.$store.state.lobby.members.filter(member => {\n        return member.summonerName == invite.summonerName;\n      }).length > 0;\n    },\n    getQueueType() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"TWISTED_TREELINE_DRAFT\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\n      }\n    },\n    getMapPreview() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"SUMMONERS_RIFT_BLIND\":\n          return \"static/images/general/sr-preview.png\";\n        case \"TWISTED_TREELINE_DRAFT\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return \"static/images/general/tt-preview.png\";\n        case \"ARAM_BLIND\":\n          return \"static/images/general/ha-preview.png\";\n      }\n    },\n    getMapType() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"SUMMONERS_RIFT_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n        case \"TWISTED_TREELINE_DRAFT\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n      }\n    },\n    getTeamSize() {\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"ARAM_BLIND\":\n          return \"5x5\";\n        case \"TWISTED_TREELINE_DRAFT\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return \"3x3\";\n      }\n    },\n    sendLobbyChatMessage() {\n      const message = this.$refs.chatInput.value;\n      if (message.trim() == \"\") return;\n      this.$refs.chatInput.value = \"\";\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: message\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n      });\n    },\n    leaveLobby() {\n      const route = this.$route.name;\n      const router = this.$router;\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        if (route != \"Home\") {\n          router.push(\"/LoggedIn/home\");\n        }\n      });\n    },\n    startQueue() {\n      if (this.inQueue) return;\n      this.$sound.template(\"OVERVIEW_PLAYBUTTON\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_START\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n          if (error && error.message && error.code === 140) {\n            this.$store.dispatch(\"socketRecievedLobbyChat\", {\n              from: \"SYSTEM\",\n              to: null,\n              data: error.message\n            });\n          }\n        }\n        console.log(response);\n      });\n    },\n    stopQueue() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$store.dispatch(\"clearLobbyTimers\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_STOP\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$store.dispatch(\"setLobbyQueueState\", false);\n        console.log(response);\n      });\n    },\n    switchTeam() {\n      if (this.inQueue) return;\n      this.$socket.sendLobbyMessage(\"LOBBY_SWITCH_TEAM\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n      });\n    }\n  },\n  beforeMount() {\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\n    this.$store.dispatch(\"changeBackgroundState\", \"CUSTOM_LOBBY\");\n  },\n  updated() {\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\n      this.lastMessages = this.lobbyChatMessages.length;\n      this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n    }\n  },\n  created() {\n    this.$store.dispatch(\"getServerCount\");\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","components","data","lastMessages","queueNumber","showBotModal","botDifficulty","selectedChampion","id","name","targetTeam","botTeam1","botTeam2","championList","computed","isTeamFull","players1","players2","user","$store","state","summonerName","team1","some","c","team2","length","lobby","members","filter","lobbyTeam","undefined","lobbyChatMessages","lobbyInvites","invited","inQueue","owner","lobbyOwner","serverCount","currentLobbyPlayer","member","methods","addBotToTeam1","addBotToTeam2","closeBotModal","confirmAddBot","bot","iconId","level","isBot","push","canJoinTeam","team","getInviteStatus","status","$translate","text","inLobby","invite","getQueueType","lobbyType","getMapPreview","getMapType","getTeamSize","sendLobbyChatMessage","message","$refs","chatInput","value","trim","$socket","sendLobbyMessage","response","error","console","log","chatMessages","scrollTop","scrollHeight","leaveLobby","route","$route","router","$router","startQueue","$sound","template","code","dispatch","from","to","stopQueue","switchTeam","beforeMount","updated","created"],"sources":["src/views/LobbyCustom.vue"],"sourcesContent":["<template>\r\n  <div id=\"LobbyCustom\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players\">\r\n            <div class=\"team lolblock\">\r\n              <div class=\"head\">\r\n                {{\r\n                  tWithParams(\"CTLOBBY_TEAM1_TITLE\", {\r\n                    serverCount\r\n                  })\r\n                }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <Player\r\n                  v-for=\"(player, index) in players1\"\r\n                  :key=\"index\"\r\n                  :summoner=\"player\"\r\n                  :custom=\"true\"\r\n                />\r\n\r\n                <!-- 机器人：己方队伍 -->\r\n                <Player\r\n                  v-for=\"(bot, index) in botTeam1\"\r\n                  :key=\"'bot1_' + index\"\r\n                  :summoner=\"bot\"\r\n                  :custom=\"true\"\r\n                  :is-bot=\"true\"\r\n                />\r\n\r\n                <div v-if=\"canJoinTeam(1)\" class=\"joinTeam\">\r\n                  <button @click=\"switchTeam\">\r\n                    {{ t(\"CTLOBBY_JOIN_TEAM_BTN\") }}\r\n                  </button>\r\n                </div>\r\n\r\n                <!-- 添加机器人按钮（队伍1） -->\r\n                <div class=\"add-bot-container\" v-if=\"owner\">\r\n                  <button class=\"add-bot-btn\" @click=\"addBotToTeam1\">\r\n                    ➕ 添加机器人\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"team lolblock\">\r\n              <div class=\"head\">\r\n                {{ t(\"CTLOBBY_TEAM2_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <Player\r\n                  v-for=\"(player, index) in players2\"\r\n                  :key=\"index\"\r\n                  :summoner=\"player\"\r\n                  :custom=\"true\"\r\n                />\r\n\r\n                <!-- 机器人：敌方队伍 -->\r\n                <Player\r\n                  v-for=\"(bot, index) in botTeam2\"\r\n                  :key=\"'bot2_' + index\"\r\n                  :summoner=\"bot\"\r\n                  :custom=\"true\"\r\n                  :is-bot=\"true\"\r\n                />\r\n\r\n                <div v-if=\"canJoinTeam(2)\" class=\"joinTeam\">\r\n                  <button @click=\"switchTeam\">\r\n                    {{ t(\"CTLOBBY_JOIN_TEAM_BTN\") }}\r\n                  </button>\r\n                </div>\r\n\r\n                <!-- 添加机器人按钮（队伍2） -->\r\n                <div class=\"add-bot-container\" v-if=\"owner\">\r\n                  <button class=\"add-bot-btn\" @click=\"addBotToTeam2\">\r\n                    ➕ 添加机器人\r\n                  </button>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"actions\">\r\n              <button class=\"quitBtn\" @click=\"leaveLobby\">\r\n                {{ t(\"CTLOBBY_QUIT_GAME_BTN\") }}\r\n              </button>\r\n              <button class=\"changeBtn\" @click=\"$router.push('/LoggedIn/play')\">\r\n                {{ t(\"CTLOBBY_CHANGE_LOBBY_TYPE_BTN\") }}\r\n              </button>\r\n              <button class=\"startBtn\" v-if=\"owner\" @click=\"startQueue\">\r\n                {{ t(\"CTLOBBY_START_GAME_BTN\") }}\r\n              </button>\r\n            </div>\r\n          </div>\r\n          <div class=\"chat lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_ALLCHAT_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div class=\"chat-messages\" ref=\"chatMessages\">\r\n                <ChatMessage\r\n                  v-for=\"(message, index) in lobbyChatMessages\"\r\n                  :key=\"index\"\r\n                  :message=\"message\"\r\n                />\r\n              </div>\r\n              <div class=\"chat-input\">\r\n                <input\r\n                  type=\"text\"\r\n                  ref=\"chatInput\"\r\n                  v-on:keyup.enter=\"sendLobbyChatMessage\"\r\n                />\r\n                <button @click=\"sendLobbyChatMessage\">\r\n                  {{ t(\"LOBBY_ALLCHAT_SEND_BTN\") }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"game\">\r\n          <div class=\"map lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_MAP_OPTIONS_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <img :src=\"getMapPreview()\" class=\"preview\" alt=\"\" />\r\n              <div class=\"details\">\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_MAP\") }}:</strong>\r\n                  {{ getMapType() }}\r\n                </p>\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_TEAMSIZE\") }}:</strong>\r\n                  {{ getTeamSize() }}\r\n                </p>\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_QUEUETYPE\") }}:</strong>\r\n                  {{ getQueueType() }}\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"invites lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_INVITES_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div\r\n                class=\"invite\"\r\n                v-for=\"(invite, index) in lobbyInvites\"\r\n                :key=\"index\"\r\n              >\r\n                <span>{{ index }}</span>\r\n                <span :class=\"invite.toLowerCase()\">\r\n                  {{ getInviteStatus(invite) }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n\r\n    <!-- 添加机器人弹窗 -->\r\n    <div class=\"bot-modal\" v-if=\"showBotModal\">\r\n      <div class=\"modal-content\">\r\n        <div class=\"modal-header\">\r\n          <h3>添加机器人</h3>\r\n          <button class=\"close\" @click=\"closeBotModal\">×</button>\r\n        </div>\r\n        <div class=\"modal-body\">\r\n          <label>难度</label>\r\n          <select v-model=\"botDifficulty\">\r\n            <option value=\"EASY\">简单</option>\r\n            <option value=\"MEDIUM\">一般</option>\r\n            <option value=\"HARD\">困难</option>\r\n          </select>\r\n\r\n          <label>英雄</label>\r\n          <select v-model=\"selectedChampion\">\r\n            <option v-for=\"c in championList\" :key=\"c.id\" :value=\"c\">\r\n              {{ c.name }}\r\n            </option>\r\n          </select>\r\n        </div>\r\n        <div class=\"modal-footer\">\r\n          <button @click=\"confirmAddBot\">确认添加</button>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    ChatMessage,\r\n    SideBar,\r\n  },\r\n  data() {\r\n    return {\r\n      lastMessages: null,\r\n      queueNumber: \"-\",\r\n      showBotModal: false,\r\n      botDifficulty: \"MEDIUM\",\r\n      selectedChampion: { id: 1, name: \"安妮\" },\r\n      targetTeam: 1,\r\n      botTeam1: [],\r\n      botTeam2: [],\r\n      championList: [\r\n        { id: 1, name: \"安妮\" },\r\n        { id: 6, name: \"盖伦\" },\r\n        { id: 7, name: \"艾希\" },\r\n        { id: 9, name: \"易大师\" },\r\n        { id: 10, name: \"瑞兹\" },\r\n      ],\r\n    };\r\n  },\r\n  computed: {\r\n    isTeamFull() {\r\n      if (this.players1 && this.players2) {\r\n        let user = this.$store.state.user.summonerName;\r\n        let team1 = this.players1.some((c) => c.summonerName == user);\r\n        let team2 = this.players2.some((c) => c.summonerName == user);\r\n\r\n        if (team1 && this.players2.length <= 5) {\r\n          return false;\r\n        } else if (team2 && this.players1.length <= 5) {\r\n          return false;\r\n        }\r\n      }\r\n      return true;\r\n    },\r\n    ...mapState({\r\n      players1: (state) =>\r\n        state.lobby.members\r\n          ? state.lobby.members.filter((c) => c.lobbyTeam === \"TEAM1\")\r\n          : undefined,\r\n      players2: (state) =>\r\n        state.lobby.members\r\n          ? state.lobby.members.filter((c) => c.lobbyTeam === \"TEAM2\")\r\n          : undefined,\r\n      lobbyChatMessages: (state) => state.lobbyChatMessages,\r\n      lobbyInvites: (state) => state.lobby.invited,\r\n      inQueue: (state) => state.lobby.inQueue,\r\n      owner: (state) => state.lobbyOwner,\r\n      serverCount: (state) => state.serverCount,\r\n      currentLobbyPlayer: (state) => {\r\n        return state.lobby.members.filter((member) => {\r\n          return member.summonerName == state.user.summonerName;\r\n        })[0];\r\n      },\r\n    }),\r\n  },\r\n  methods: {\r\n    // 机器人功能\r\n    addBotToTeam1() {\r\n      this.targetTeam = 1;\r\n      this.showBotModal = true;\r\n    },\r\n    addBotToTeam2() {\r\n      this.targetTeam = 2;\r\n      this.showBotModal = true;\r\n    },\r\n    closeBotModal() {\r\n      this.showBotModal = false;\r\n    },\r\n    confirmAddBot() {\r\n      const bot = {\r\n        summonerName: this.selectedChampion.name + \" (AI)\",\r\n        iconId: 1,\r\n        level: 30,\r\n        isBot: true,\r\n        lobbyTeam: this.targetTeam === 1 ? \"TEAM1\" : \"TEAM2\",\r\n      };\r\n\r\n      if (this.targetTeam === 1) {\r\n        this.botTeam1.push(bot);\r\n      } else {\r\n        this.botTeam2.push(bot);\r\n      }\r\n\r\n      this.closeBotModal();\r\n    },\r\n\r\n    canJoinTeam(team) {\r\n      if (this.players1 && this.players2) {\r\n        if (team == 2) {\r\n          return (\r\n            this.players2.length != 5 &&\r\n            this.currentLobbyPlayer.lobbyTeam == \"TEAM1\" &&\r\n            !this.isTeamFull\r\n          );\r\n        } else {\r\n          return (\r\n            this.players1.length != 5 &&\r\n            this.currentLobbyPlayer.lobbyTeam == \"TEAM2\" &&\r\n            !this.isTeamFull\r\n          );\r\n        }\r\n      } else {\r\n        return false;\r\n      }\r\n    },\r\n    getInviteStatus(status) {\r\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\r\n    },\r\n    inLobby(invite) {\r\n      return (\r\n        this.$store.state.lobby.members.filter((member) => {\r\n          return member.summonerName == invite.summonerName;\r\n        }).length > 0\r\n      );\r\n    },\r\n    getQueueType() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\r\n      }\r\n    },\r\n    getMapPreview() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n          return \"static/images/general/sr-preview.png\";\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return \"static/images/general/tt-preview.png\";\r\n        case \"ARAM_BLIND\":\r\n          return \"static/images/general/ha-preview.png\";\r\n      }\r\n    },\r\n    getMapType() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\r\n      }\r\n    },\r\n    getTeamSize() {\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"ARAM_BLIND\":\r\n          return \"5x5\";\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n        case \"TW