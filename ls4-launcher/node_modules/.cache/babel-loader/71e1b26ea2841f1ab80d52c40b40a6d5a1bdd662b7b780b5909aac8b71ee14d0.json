{"ast":null,"code":"import \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nexport default {\n  props: {\n    custom: {\n      type: Boolean,\n      default: false\n    },\n    summoner: {\n      type: Object,\n      required: true\n    },\n    isBotGame: {\n      type: Boolean,\n      default: false\n    },\n    botDifficulty: {\n      type: String,\n      default: null\n    }\n  },\n  computed: {\n    aiDifficultyMap() {\n      return {\n        BEGINNER: this.$translate?.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\") || \"入门\",\n        INTERMEDIATE: this.$translate?.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\") || \"中等\",\n        ADVANCED: this.$translate?.text(\"PLAY_DATA_DIFFICULTY_ADVANCED\") || \"高级\"\n      };\n    }\n  },\n  mounted() {\n    console.log(\"Player mounted:\", this.summoner);\n  },\n  methods: {\n    getDisplayName() {\n      // 如果是人机模式且是AI玩家\n      if (this.isBotGame && this.summoner.isAI) {\n        return this.getAIDisplayName();\n      }\n      // 普通玩家显示召唤师名称\n      return this.summoner.summonerName;\n    },\n    getAIDisplayName() {\n      const difficulty = this.getAIDifficultyText();\n      // 从 summoner 中获取 AI 编号，如果没有则使用索引\n      const aiNumber = this.summoner.aiNumber || \"\";\n      return `${difficulty} AI ${aiNumber}`.trim();\n    },\n    getAIDifficultyText() {\n      const difficulty = this.summoner.aiDifficulty || this.botDifficulty;\n      if (difficulty && this.aiDifficultyMap[difficulty]) {\n        return this.aiDifficultyMap[difficulty];\n      }\n      return this.aiDifficultyMap.INTERMEDIATE;\n    },\n    getSummonerIconUrl() {\n      // AI 玩家使用默认头像\n      if (this.summoner.isAI) {\n        return this.getAIIconUrl();\n      }\n      const {\n        host,\n        port\n      } = this.$store.state.config.download;\n      return `${host}:${port}/summoner_icons/${this.summoner.summonerIconId}.png`;\n    },\n    getAIIconUrl() {\n      // 根据难度返回不同的 AI 头像\n      const difficulty = this.summoner.aiDifficulty || this.botDifficulty;\n      const iconMap = {\n        BEGINNER: \"static/images/ai/ai_beginner.png\",\n        INTERMEDIATE: \"static/images/ai/ai_intermediate.png\",\n        ADVANCED: \"static/images/ai/ai_advanced.png\"\n      };\n      return iconMap[difficulty] || iconMap.INTERMEDIATE;\n    },\n    isCaptain() {\n      if (this.summoner.isAI) return false;\n      if (!this.$store.state.lobby.owner) return false;\n      return this.summoner.summonerName == this.$store.state.lobby.owner.summonerName;\n    },\n    canKick() {\n      return this.$store.state.lobbyOwner && this.summoner.summonerName != this.$store.state.user.summonerName && !this.summoner.isAI;\n    },\n    isFriend() {\n      if (this.summoner.isAI) return false;\n      if (this.summoner.summonerName == this.$store.state.user.summonerName) {\n        return true;\n      }\n      return this.$store.state.friendList.filter(friend => {\n        return friend.summonerName == this.summoner.summonerName;\n      }).length > 0;\n    },\n    addFriend() {\n      this.$socket.sendSystemMessage(\"FRIEND_OUT\", {\n        data: this.summoner.summonerName\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n      });\n    },\n    kickUser() {\n      this.$socket.sendLobbyMessage(\"LOBBY_KICK\", {\n        data: this.summoner.summonerName\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n      });\n    }\n  }\n};","map":{"version":3,"names":["props","custom","type","Boolean","default","summoner","Object","required","isBotGame","botDifficulty","String","computed","aiDifficultyMap","BEGINNER","$translate","text","INTERMEDIATE","ADVANCED","mounted","console","log","methods","getDisplayName","isAI","getAIDisplayName","summonerName","difficulty","getAIDifficultyText","aiNumber","trim","aiDifficulty","getSummonerIconUrl","getAIIconUrl","host","port","$store","state","config","download","summonerIconId","iconMap","isCaptain","lobby","owner","canKick","lobbyOwner","user","isFriend","friendList","filter","friend","length","addFriend","$socket","sendSystemMessage","data","response","error","kickUser","sendLobbyMessage"],"sources":["src/components/Lobby/Player.vue"],"sourcesContent":["<template>\r\n  <div class=\"player\" :class=\"{ custom: custom, 'ai-player': summoner.isAI }\">\r\n    <div class=\"icon\">\r\n      <img :src=\"getSummonerIconUrl()\" alt=\"summonerIcon\" />\r\n      <div v-if=\"summoner.isAI\" class=\"ai-badge\">\r\n        <i class=\"fas fa-robot\"></i>\r\n      </div>\r\n    </div>\r\n    <div class=\"details\">\r\n      <div\r\n        class=\"name\"\r\n        :class=\"{ \r\n          shop_colored_name: summoner.nameColourUnlocked,\r\n          'ai-name': summoner.isAI\r\n        }\"\r\n      >\r\n        {{ getDisplayName() }}\r\n      </div>\r\n      <div class=\"level\" v-if=\"!summoner.isAI\">\r\n        Level {{ summoner.summonerLevel }}\r\n      </div>\r\n      <div class=\"level ai-difficulty\" v-if=\"summoner.isAI && botDifficulty\">\r\n        {{ getAIDifficultyText() }}\r\n      </div>\r\n      <div class=\"badges\">\r\n        <div class=\"badge\" v-if=\"isCaptain() && !summoner.isAI\">\r\n          <img src=\"@/assets/images/captain_logo.png\" alt=\"captain\" />\r\n        </div>\r\n        <div class=\"badge disabled btn\" v-if=\"!summoner.isAI\">\r\n          <img\r\n            src=\"@/assets/images/lobby_small_btn.png\"\r\n            alt=\"lobbyProfileBtn\"\r\n          />\r\n          <i class=\"fas fa-user\"></i>\r\n        </div>\r\n        <div class=\"badge btn\" v-if=\"!isFriend() && !summoner.isAI && !isBotGame\">\r\n          <img\r\n            src=\"@/assets/images/lobby_adduser_btn.png\"\r\n            alt=\"addFriendBtn\"\r\n            @click=\"addFriend\"\r\n          />\r\n        </div>\r\n        <div class=\"badge btn\" v-if=\"canKick() && !summoner.isAI\">\r\n          <img\r\n            src=\"@/assets/images/lobby_small_btn.png\"\r\n            alt=\"kickUserBtn\"\r\n            @click=\"kickUser\"\r\n          />\r\n          <i class=\"fas fa-times\"></i>\r\n        </div>\r\n      </div>\r\n    </div>\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nexport default {\r\n  props: {\r\n    custom: {\r\n      type: Boolean,\r\n      default: false\r\n    },\r\n    summoner: {\r\n      type: Object,\r\n      required: true\r\n    },\r\n    isBotGame: {\r\n      type: Boolean,\r\n      default: false\r\n    },\r\n    botDifficulty: {\r\n      type: String,\r\n      default: null\r\n    }\r\n  },\r\n  computed: {\r\n    aiDifficultyMap() {\r\n      return {\r\n        BEGINNER: this.$translate?.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\") || \"入门\",\r\n        INTERMEDIATE: this.$translate?.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\") || \"中等\",\r\n        ADVANCED: this.$translate?.text(\"PLAY_DATA_DIFFICULTY_ADVANCED\") || \"高级\"\r\n      };\r\n    }\r\n  },\r\n  mounted() {\r\n    console.log(\"Player mounted:\", this.summoner);\r\n  },\r\n  methods: {\r\n    getDisplayName() {\r\n      // 如果是人机模式且是AI玩家\r\n      if (this.isBotGame && this.summoner.isAI) {\r\n        return this.getAIDisplayName();\r\n      }\r\n      // 普通玩家显示召唤师名称\r\n      return this.summoner.summonerName;\r\n    },\r\n    \r\n    getAIDisplayName() {\r\n      const difficulty = this.getAIDifficultyText();\r\n      // 从 summoner 中获取 AI 编号，如果没有则使用索引\r\n      const aiNumber = this.summoner.aiNumber || \"\";\r\n      return `${difficulty} AI ${aiNumber}`.trim();\r\n    },\r\n    \r\n    getAIDifficultyText() {\r\n      const difficulty = this.summoner.aiDifficulty || this.botDifficulty;\r\n      if (difficulty && this.aiDifficultyMap[difficulty]) {\r\n        return this.aiDifficultyMap[difficulty];\r\n      }\r\n      return this.aiDifficultyMap.INTERMEDIATE;\r\n    },\r\n    \r\n    getSummonerIconUrl() {\r\n      // AI 玩家使用默认头像\r\n      if (this.summoner.isAI) {\r\n        return this.getAIIconUrl();\r\n      }\r\n      const { host, port } = this.$store.state.config.download;\r\n      return `${host}:${port}/summoner_icons/${this.summoner.summonerIconId}.png`;\r\n    },\r\n    \r\n    getAIIconUrl() {\r\n      // 根据难度返回不同的 AI 头像\r\n      const difficulty = this.summoner.aiDifficulty || this.botDifficulty;\r\n      const iconMap = {\r\n        BEGINNER: \"static/images/ai/ai_beginner.png\",\r\n        INTERMEDIATE: \"static/images/ai/ai_intermediate.png\",\r\n        ADVANCED: \"static/images/ai/ai_advanced.png\"\r\n      };\r\n      return iconMap[difficulty] || iconMap.INTERMEDIATE;\r\n    },\r\n    \r\n    isCaptain() {\r\n      if (this.summoner.isAI) return false;\r\n      if (!this.$store.state.lobby.owner) return false;\r\n      return (\r\n        this.summoner.summonerName == this.$store.state.lobby.owner.summonerName\r\n      );\r\n    },\r\n    \r\n    canKick() {\r\n      return (\r\n        this.$store.state.lobbyOwner &&\r\n        this.summoner.summonerName != this.$store.state.user.summonerName &&\r\n        !this.summoner.isAI\r\n      );\r\n    },\r\n    \r\n    isFriend() {\r\n      if (this.summoner.isAI) return false;\r\n      if (this.summoner.summonerName == this.$store.state.user.summonerName) {\r\n        return true;\r\n      }\r\n      return (\r\n        this.$store.state.friendList.filter(friend => {\r\n          return friend.summonerName == this.summoner.summonerName;\r\n        }).length > 0\r\n      );\r\n    },\r\n    \r\n    addFriend() {\r\n      this.$socket.sendSystemMessage(\r\n        \"FRIEND_OUT\",\r\n        { data: this.summoner.summonerName },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n        }\r\n      );\r\n    },\r\n    \r\n    kickUser() {\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_KICK\",\r\n        { data: this.summoner.summonerName },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n        }\r\n      );\r\n    }\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"scss\" scoped>\r\n.player {\r\n  width: 100%;\r\n  height: 17%;\r\n  background-blend-mode: multiply;\r\n  border: 1.5px solid #474b4c;\r\n  border-radius: 4px;\r\n  background: url(\"../../assets/images/noise-mask.png\"),\r\n    linear-gradient(180deg, #363636 0%, #090b0a 100%);\r\n  display: flex;\r\n  margin-bottom: 5px;\r\n  padding: 4px;\r\n  position: relative;\r\n  transition: all 0.3s ease;\r\n}\r\n\r\n/* AI 玩家特殊样式 */\r\n.player.ai-player {\r\n  background: url(\"../../assets/images/noise-mask.png\"),\r\n    linear-gradient(180deg, #2a4a2a 0%, #0a2a0a 100%);\r\n  border-color: #4a9e4a;\r\n  box-shadow: 0 0 5px rgba(74, 158, 74, 0.3);\r\n}\r\n\r\n.player.ai-player .icon {\r\n  position: relative;\r\n}\r\n\r\n.player.ai-player .icon .ai-badge {\r\n  position: absolute;\r\n  bottom: -5px;\r\n  right: -5px;\r\n  background: rgba(0, 0, 0, 0.8);\r\n  border-radius: 50%;\r\n  width: 18px;\r\n  height: 18px;\r\n  display: flex;\r\n  align-items: center;\r\n  justify-content: center;\r\n  border: 1px solid #4a9e4a;\r\n}\r\n\r\n.player.ai-player .icon .ai-badge i {\r\n  font-size: 10px;\r\n  color: #4a9e4a;\r\n}\r\n\r\n.player .icon {\r\n  margin-right: 10px;\r\n  width: 55px;\r\n  height: 55px;\r\n  position: relative;\r\n}\r\n\r\n.player.custom .icon {\r\n  width: 50px;\r\n  height: 50px;\r\n}\r\n\r\n.player .icon img {\r\n  width: 100%;\r\n  height: 100%;\r\n  border-radius: 4px;\r\n  object-fit: cover;\r\n}\r\n\r\n.player .details {\r\n  display: flex;\r\n  height: 100%;\r\n  width: 200px;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n}\r\n\r\n.player .details .name {\r\n  height: 35%;\r\n  font-size: 14px;\r\n  font-family: LoLFont2;\r\n  font-weight: bold;\r\n  overflow: hidden;\r\n  text-overflow: ellipsis;\r\n  white-space: nowrap;\r\n}\r\n\r\n.player .details .name.ai-name {\r\n  color: #88ff88;\r\n  text-shadow: 0 0 3px rgba(136, 255, 136, 0.5);\r\n}\r\n\r\n.player .details .level {\r\n  height: 23%;\r\n  font-size: 10px;\r\n  font-family: LoLFont2;\r\n  color: #b0b0b0;\r\n}\r\n\r\n.player .details .level.ai-difficulty {\r\n  color: #ffaa44;\r\n  font-weight: bold;\r\n}\r\n\r\n.player .details .badges {\r\n  height: 42%;\r\n  padding: 2px 0;\r\n  display: flex;\r\n  align-items: center;\r\n}\r\n\r\n.player .details .badges .badge {\r\n  margin-right: 10px;\r\n  height: 100%;\r\n  width: 15px;\r\n  position: relative;\r\n}\r\n\r\n.player .details .badges .badge.btn {\r\n  transition: filter ease-in-out 200ms;\r\n  cursor: pointer;\r\n}\r\n\r\n.player .details .badges .badge.btn:not(.disabled):hover {\r\n  filter: brightness(1.25);\r\n}\r\n\r\n.player .details .badges .badge.disabled {\r\n  filter: grayscale(100%);\r\n  cursor: not-allowed;\r\n}\r\n\r\n.player .details .badges .badge i {\r\n  font-size: 10px;\r\n  position: absolute;\r\n  left: 50%;\r\n  top: 50%;\r\n  transform: translate(-50%, -50%);\r\n  color: white;\r\n}\r\n\r\n.player .details .badges .badge img {\r\n  position: absolute;\r\n  left: 50%;\r\n  top: 50%;\r\n  transform: translate(-50%, -50%);\r\n  height: 100%;\r\n  width: auto;\r\n  object-fit: contain;\r\n  object-position: center;\r\n}\r\n\r\n/* 响应式调整 */\r\n@media (max-width: 1200px) {\r\n  .player .details {\r\n    width: 150px;\r\n  }\r\n  \r\n  .player .details .name {\r\n    font-size: 12px;\r\n  }\r\n  \r\n  .player .details .level {\r\n    font-size: 9px;\r\n  }\r\n}\r\n\r\n@media (max-width: 768px) {\r\n  .player .details {\r\n    width: 120px;\r\n  }\r\n  \r\n  .player .icon {\r\n    width: 45px;\r\n    height: 45px;\r\n  }\r\n  \r\n  .player .details .name {\r\n    font-size: 11px;\r\n  }\r\n  \r\n  .player .details .level {\r\n    font-size: 8px;\r\n  }\r\n}\r\n\r\n/* 动画效果 */\r\n@keyframes aiPulse {\r\n  0% {\r\n    box-shadow: 0 0 0 0 rgba(74, 158, 74, 0.4);\r\n  }\r\n  70% {\r\n    box-shadow: 0 0 0 5px rgba(74, 158, 74, 0);\r\n  }\r\n  100% {\r\n    box-shadow: 0 0 0 0 rgba(74, 158, 74, 0);\r\n  }\r\n}\r\n\r\n.player.ai-player:not(.custom) {\r\n  animation: aiPulse 2s infinite;\r\n}\r\n</style>"],"mappings":";;AAwDA;EACAA,KAAA;IACAC,MAAA;MACAC,IAAA,EAAAC,OAAA;MACAC,OAAA;IACA;IACAC,QAAA;MACAH,IAAA,EAAAI,MAAA;MACAC,QAAA;IACA;IACAC,SAAA;MACAN,IAAA,EAAAC,OAAA;MACAC,OAAA;IACA;IACAK,aAAA;MACAP,IAAA,EAAAQ,MAAA;MACAN,OAAA;IACA;EACA;EACAO,QAAA;IACAC,gBAAA;MACA;QACAC,QAAA,OAAAC,UAAA,EAAAC,IAAA;QACAC,YAAA,OAAAF,UAAA,EAAAC,IAAA;QACAE,QAAA,OAAAH,UAAA,EAAAC,IAAA;MACA;IACA;EACA;EACAG,QAAA;IACAC,OAAA,CAAAC,GAAA,yBAAAf,QAAA;EACA;EACAgB,OAAA;IACAC,eAAA;MACA;MACA,SAAAd,SAAA,SAAAH,QAAA,CAAAkB,IAAA;QACA,YAAAC,gBAAA;MACA;MACA;MACA,YAAAnB,QAAA,CAAAoB,YAAA;IACA;IAEAD,iBAAA;MACA,MAAAE,UAAA,QAAAC,mBAAA;MACA;MACA,MAAAC,QAAA,QAAAvB,QAAA,CAAAuB,QAAA;MACA,UAAAF,UAAA,OAAAE,QAAA,GAAAC,IAAA;IACA;IAEAF,oBAAA;MACA,MAAAD,UAAA,QAAArB,QAAA,CAAAyB,YAAA,SAAArB,aAAA;MACA,IAAAiB,UAAA,SAAAd,eAAA,CAAAc,UAAA;QACA,YAAAd,eAAA,CAAAc,UAAA;MACA;MACA,YAAAd,eAAA,CAAAI,YAAA;IACA;IAEAe,mBAAA;MACA;MACA,SAAA1B,QAAA,CAAAkB,IAAA;QACA,YAAAS,YAAA;MACA;MACA;QAAAC,IAAA;QAAAC;MAAA,SAAAC,MAAA,CAAAC,KAAA,CAAAC,MAAA,CAAAC,QAAA;MACA,UAAAL,IAAA,IAAAC,IAAA,wBAAA7B,QAAA,CAAAkC,cAAA;IACA;IAEAP,aAAA;MACA;MACA,MAAAN,UAAA,QAAArB,QAAA,CAAAyB,YAAA,SAAArB,aAAA;MACA,MAAA+B,OAAA;QACA3B,QAAA;QACAG,YAAA;QACAC,QAAA;MACA;MACA,OAAAuB,OAAA,CAAAd,UAAA,KAAAc,OAAA,CAAAxB,YAAA;IACA;IAEAyB,UAAA;MACA,SAAApC,QAAA,CAAAkB,IAAA;MACA,UAAAY,MAAA,CAAAC,KAAA,CAAAM,KAAA,CAAAC,KAAA;MACA,OACA,KAAAtC,QAAA,CAAAoB,YAAA,SAAAU,MAAA,CAAAC,KAAA,CAAAM,KAAA,CAAAC,KAAA,CAAAlB,YAAA;IAEA;IAEAmB,QAAA;MACA,OACA,KAAAT,MAAA,CAAAC,KAAA,CAAAS,UAAA,IACA,KAAAxC,QAAA,CAAAoB,YAAA,SAAAU,MAAA,CAAAC,KAAA,CAAAU,IAAA,CAAArB,YAAA,IACA,MAAApB,QAAA,CAAAkB,IAAA;IAEA;IAEAwB,SAAA;MACA,SAAA1C,QAAA,CAAAkB,IAAA;MACA,SAAAlB,QAAA,CAAAoB,YAAA,SAAAU,MAAA,CAAAC,KAAA,CAAAU,IAAA,CAAArB,YAAA;QA