{"ast":null,"code":"import \"core-js/modules/es.array.push.js\";\nimport \"core-js/modules/es.iterator.constructor.js\";\nimport \"core-js/modules/es.iterator.every.js\";\nimport \"core-js/modules/es.iterator.filter.js\";\nimport \"core-js/modules/es.iterator.some.js\";\nimport Player from \"@/components/Lobby/Player.vue\";\nimport SideBar from \"@/components/SideBar.vue\";\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\nimport { mapState } from \"vuex\";\nexport default {\n  components: {\n    Player,\n    ChatMessage,\n    SideBar\n  },\n  data() {\n    return {\n      lastMessages: null,\n      queueNumber: \"-\"\n    };\n  },\n  computed: {\n    isTeamFull() {\n      if (this.players1 && this.players2) {\n        let user = this.$store.state.user.summonerName;\n        let team1 = this.players1.some(c => c.summonerName == user);\n        let team2 = this.players2.some(c => c.summonerName == user);\n        if (team1 && this.players2.length <= 5) {\n          return false;\n        } else if (team2 && this.players1.length <= 5) {\n          return false;\n        }\n      }\n      return true;\n    },\n    ...mapState({\n      players1: state => state.lobby.members ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM1\") : undefined,\n      players2: state => state.lobby.members ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM2\") : undefined,\n      lobbyChatMessages: state => state.lobbyChatMessages,\n      lobbyInvites: state => state.lobby.invited,\n      inQueue: state => state.lobby.inQueue,\n      owner: state => state.lobbyOwner,\n      serverCount: state => state.serverCount,\n      isBotGame: state => state.lobby.isBotGame || false,\n      botDifficulty: state => state.lobby.botDifficulty,\n      currentLobbyPlayer: state => {\n        return state.lobby.members.filter(member => {\n          return member.summonerName == state.user.summonerName;\n        })[0];\n      },\n      isHumanPlayer: state => {\n        if (!state.lobby.isBotGame) return true;\n        const currentUser = state.user.summonerName;\n        return state.lobby.members.some(member => member.summonerName === currentUser && !member.isAI);\n      },\n      humanPlayersCount: state => {\n        if (!state.lobby.isBotGame) return 0;\n        return state.lobby.members.filter(member => !member.isAI).length;\n      },\n      canStartBotGame: state => {\n        if (!state.lobby.isBotGame) return true;\n        return state.lobby.members.some(member => !member.isAI);\n      }\n    })\n  },\n  methods: {\n    getMaxPlayers() {\n      const teamSize = this.getTeamSize();\n      if (teamSize === \"5x5\") return 5;\n      if (teamSize === \"3x3\") return 3;\n      return 5;\n    },\n    isTeamAI(teamNumber) {\n      const team = teamNumber === 1 ? this.players1 : this.players2;\n      if (!team || team.length === 0) return false;\n      // 检查队伍是否全部是AI\n      return team.every(player => player.isAI === true);\n    },\n    getBotDifficultyText() {\n      const difficulties = {\n        BEGINNER: this.$translate.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\"),\n        INTERMEDIATE: this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\"),\n        ADVANCED: this.$translate.text(\"PLAY_DATA_DIFFICULTY_ADVANCED\")\n      };\n      return difficulties[this.botDifficulty] || this.botDifficulty || this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\");\n    },\n    getBotDifficultyDescription() {\n      const descriptions = {\n        BEGINNER: this.$translate.text(\"LOBBY_AI_DIFFICULTY_BEGINNER_DESC\"),\n        INTERMEDIATE: this.$translate.text(\"LOBBY_AI_DIFFICULTY_INTERMEDIATE_DESC\"),\n        ADVANCED: this.$translate.text(\"LOBBY_AI_DIFFICULTY_ADVANCED_DESC\")\n      };\n      return descriptions[this.botDifficulty] || this.$translate.text(\"LOBBY_AI_DEFAULT_DESC\");\n    },\n    getStartButtonText() {\n      if (this.isBotGame) {\n        if (!this.canStartBotGame) {\n          return this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS\");\n        }\n        return this.$translate.text(\"CTLOBBY_START_GAME_BTN\");\n      }\n      return this.$translate.text(\"CTLOBBY_START_GAME_BTN\");\n    },\n    getChatPlaceholder() {\n      if (this.isBotGame && !this.isHumanPlayer) {\n        return this.$translate.text(\"LOBBY_AI_CANNOT_CHAT\");\n      }\n      return this.$translate.text(\"LOBBY_ALLCHAT_PLACEHOLDER\");\n    },\n    canJoinTeam(team) {\n      if (this.isBotGame) return false; // 人机模式不允许切换队伍\n      if (this.players1 && this.players2) {\n        if (team == 2) {\n          return this.players2.length != 5 && this.currentLobbyPlayer.lobbyTeam == \"TEAM1\" && !this.isTeamFull;\n        } else {\n          return this.players1.length != 5 && this.currentLobbyPlayer.lobbyTeam == \"TEAM2\" && !this.isTeamFull;\n        }\n      } else {\n        return false;\n      }\n    },\n    getInviteStatus(status) {\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\n    },\n    inLobby(invite) {\n      return this.$store.state.lobby.members.filter(member => {\n        return member.summonerName == invite.summonerName;\n      }).length > 0;\n    },\n    getQueueType() {\n      if (this.isBotGame) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_BOT\");\n      }\n      switch (this.$store.state.lobby.lobbyType) {\n        case \"SUMMONERS_RIFT_DRAFT\":\n        case \"TWISTED_TREELINE_DRAFT\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\n        case \"SUMMONERS_RIFT_BLIND\":\n        case \"TWISTED_TREELINE_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\n        case \"ARAM_BLIND\":\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\n        default:\n          return \"\";\n      }\n    },\n    getMapPreview() {\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\n        return \"static/images/general/sr-preview.png\";\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return \"static/images/general/tt-preview.png\";\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\n        return \"static/images/general/ha-preview.png\";\n      }\n      return \"static/images/general/sr-preview.png\";\n    },\n    getMapType() {\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\n      }\n      return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\n    },\n    getTeamSize() {\n      const lobbyType = this.$store.state.lobby.lobbyType;\n      if (lobbyType && (lobbyType.includes(\"SUMMONERS_RIFT\") || lobbyType.includes(\"ARAM\"))) {\n        return \"5x5\";\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\n        return \"3x3\";\n      }\n      return \"5x5\";\n    },\n    sendLobbyChatMessage() {\n      if (this.isBotGame && !this.isHumanPlayer) {\n        return;\n      }\n      const message = this.$refs.chatInput.value;\n      if (message.trim() == \"\") return;\n      this.$refs.chatInput.value = \"\";\n      this.$socket.sendLobbyMessage(\"LOBBY_CHAT\", {\n        data: message\n      }, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$nextTick(() => {\n          if (this.$refs.chatMessages) {\n            this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n          }\n        });\n      });\n    },\n    leaveLobby() {\n      const route = this.$route.name;\n      const router = this.$router;\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        if (route != \"Home\") {\n          router.push(\"/LoggedIn/home\");\n        }\n      });\n    },\n    startQueue() {\n      if (this.inQueue) return;\n      if (this.isBotGame) {\n        if (!this.canStartBotGame) {\n          this.$modal.setter.show({\n            title: this.$translate.text(\"LOBBY_CANNOT_START\"),\n            body: this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS_DETAIL\"),\n            footer: this.$translate.text(\"GENERAL_OK\")\n          });\n          return;\n        }\n        this.$socket.sendLobbyMessage(\"LOBBY_START_BOT_GAME\", {\n          data: {\n            difficulty: this.botDifficulty\n          }\n        }, (response, error) => {\n          if (error) {\n            console.log(\"Flyback error:\");\n            console.log(error);\n            this.$modal.setter.show({\n              title: this.$translate.text(\"LOBBY_START_FAILED\"),\n              body: error.message || this.$translate.text(\"LOBBY_START_FAILED_DESC\"),\n              footer: this.$translate.text(\"GENERAL_OK\")\n            });\n          }\n        });\n        return;\n      }\n      this.$sound.template(\"OVERVIEW_PLAYBUTTON\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_START\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n          if (error && error.message && error.code === 140) {\n            this.$store.dispatch(\"socketRecievedLobbyChat\", {\n              from: \"SYSTEM\",\n              to: null,\n              data: error.message\n            });\n          }\n        }\n        console.log(response);\n      });\n    },\n    stopQueue() {\n      this.$sound.template(\"OVERVIEW_CLICK\");\n      this.$store.dispatch(\"clearLobbyTimers\");\n      this.$socket.sendLobbyMessage(\"LOBBY_MATCHMAKING_STOP\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n        this.$store.dispatch(\"setLobbyQueueState\", false);\n        console.log(response);\n      });\n    },\n    switchTeam() {\n      if (this.inQueue) return;\n      this.$socket.sendLobbyMessage(\"LOBBY_SWITCH_TEAM\", {}, (response, error) => {\n        if (error) {\n          console.log(\"Flyback error:\");\n          console.log(error);\n        }\n      });\n    },\n    t(key, params) {\n      return this.$translate.text(key, params);\n    },\n    tWithParams(key, params) {\n      return this.$translate.text(key, params);\n    }\n  },\n  beforeMount() {\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\n    this.$store.dispatch(\"changeBackgroundState\", \"CUSTOM_LOBBY\");\n  },\n  mounted() {\n    this.$nextTick(() => {\n      if (this.$refs.chatMessages) {\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n      }\n    });\n  },\n  updated() {\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\n      this.lastMessages = this.lobbyChatMessages.length;\n      this.$nextTick(() => {\n        if (this.$refs.chatMessages) {\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\n        }\n      });\n    }\n  },\n  created() {\n    this.$store.dispatch(\"getServerCount\");\n  }\n};","map":{"version":3,"names":["Player","SideBar","ChatMessage","mapState","components","data","lastMessages","queueNumber","computed","isTeamFull","players1","players2","user","$store","state","summonerName","team1","some","c","team2","length","lobby","members","filter","lobbyTeam","undefined","lobbyChatMessages","lobbyInvites","invited","inQueue","owner","lobbyOwner","serverCount","isBotGame","botDifficulty","currentLobbyPlayer","member","isHumanPlayer","currentUser","isAI","humanPlayersCount","canStartBotGame","methods","getMaxPlayers","teamSize","getTeamSize","isTeamAI","teamNumber","team","every","player","getBotDifficultyText","difficulties","BEGINNER","$translate","text","INTERMEDIATE","ADVANCED","getBotDifficultyDescription","descriptions","getStartButtonText","getChatPlaceholder","canJoinTeam","getInviteStatus","status","inLobby","invite","getQueueType","lobbyType","getMapPreview","includes","getMapType","sendLobbyChatMessage","message","$refs","chatInput","value","trim","$socket","sendLobbyMessage","response","error","console","log","$nextTick","chatMessages","scrollTop","scrollHeight","leaveLobby","route","$route","name","router","$router","push","startQueue","$modal","setter","show","title","body","footer","difficulty","$sound","template","code","dispatch","from","to","stopQueue","switchTeam","t","key","params","tWithParams","beforeMount","mounted","updated","created"],"sources":["src/views/LobbyCustom.vue"],"sourcesContent":["<template>\r\n  <div id=\"LobbyCustom\">\r\n    <div class=\"content\">\r\n      <div class=\"mainblock\">\r\n        <div class=\"lobby\">\r\n          <div class=\"players\">\r\n            <div class=\"team lolblock\">\r\n              <div class=\"head\">\r\n                {{\r\n                  tWithParams(\"CTLOBBY_TEAM1_TITLE\", {\r\n                    serverCount\r\n                  })\r\n                }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <Player\r\n                  v-for=\"(player, index) in players1\"\r\n                  :key=\"index\"\r\n                  :summoner=\"player\"\r\n                  :custom=\"true\"\r\n                  :isBotGame=\"isBotGame\"\r\n                  :botDifficulty=\"botDifficulty\"\r\n                />\r\n                <div v-if=\"canJoinTeam(1) && !isBotGame\" class=\"joinTeam\">\r\n                  <button @click=\"switchTeam\">\r\n                    {{ t(\"CTLOBBY_JOIN_TEAM_BTN\") }}\r\n                  </button>\r\n                </div>\r\n                <div v-if=\"isBotGame && isTeamAI(1)\" class=\"ai-team-badge\">\r\n                  <i class=\"fas fa-robot\"></i>\r\n                  <span>{{ t(\"CTLOBBY_AI_TEAM\") }}</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"team lolblock\">\r\n              <div class=\"head\">\r\n                {{ t(\"CTLOBBY_TEAM2_TITLE\") }}\r\n              </div>\r\n              <div class=\"inner\">\r\n                <Player\r\n                  v-for=\"(player, index) in players2\"\r\n                  :key=\"index\"\r\n                  :summoner=\"player\"\r\n                  :custom=\"true\"\r\n                  :isBotGame=\"isBotGame\"\r\n                  :botDifficulty=\"botDifficulty\"\r\n                />\r\n                <div v-if=\"canJoinTeam(2) && !isBotGame\" class=\"joinTeam\">\r\n                  <button @click=\"switchTeam\">\r\n                    {{ t(\"CTLOBBY_JOIN_TEAM_BTN\") }}\r\n                  </button>\r\n                </div>\r\n                <div v-if=\"isBotGame && isTeamAI(2)\" class=\"ai-team-badge\">\r\n                  <i class=\"fas fa-robot\"></i>\r\n                  <span>{{ t(\"CTLOBBY_AI_TEAM\") }}</span>\r\n                </div>\r\n              </div>\r\n            </div>\r\n            <div class=\"actions\">\r\n              <button class=\"quitBtn\" @click=\"leaveLobby\">\r\n                {{ t(\"CTLOBBY_QUIT_GAME_BTN\") }}\r\n              </button>\r\n              <button class=\"changeBtn\" @click=\"$router.push('/LoggedIn/play')\">\r\n                {{ t(\"CTLOBBY_CHANGE_LOBBY_TYPE_BTN\") }}\r\n              </button>\r\n              <button class=\"startBtn\" v-if=\"owner\" @click=\"startQueue\" :disabled=\"isBotGame && !canStartBotGame\">\r\n                {{ getStartButtonText() }}\r\n              </button>\r\n            </div>\r\n          </div>\r\n          <div class=\"chat lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_ALLCHAT_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div class=\"chat-messages\" ref=\"chatMessages\">\r\n                <ChatMessage\r\n                  v-for=\"(message, index) in lobbyChatMessages\"\r\n                  :key=\"index\"\r\n                  :message=\"message\"\r\n                />\r\n              </div>\r\n              <div class=\"chat-input\">\r\n                <input\r\n                  type=\"text\"\r\n                  ref=\"chatInput\"\r\n                  v-on:keyup.enter=\"sendLobbyChatMessage\"\r\n                  :disabled=\"isBotGame && !isHumanPlayer\"\r\n                  :placeholder=\"getChatPlaceholder()\"\r\n                />\r\n                <button @click=\"sendLobbyChatMessage\" :disabled=\"isBotGame && !isHumanPlayer\">\r\n                  {{ t(\"LOBBY_ALLCHAT_SEND_BTN\") }}\r\n                </button>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <div class=\"game\">\r\n          <div class=\"map lolblock\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_MAP_OPTIONS_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <img :src=\"getMapPreview()\" class=\"preview\" alt=\"\" />\r\n              <div class=\"details\">\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_MAP\") }}:</strong>\r\n                  {{ getMapType() }}\r\n                </p>\r\n                <p>\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_TEAMSIZE\") }}:</strong>\r\n                  {{ getTeamSize() }}\r\n                </p>\r\n                <p v-if=\"!isBotGame\">\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_QUEUETYPE\") }}:</strong>\r\n                  {{ getQueueType() }}\r\n                </p>\r\n                <p v-if=\"isBotGame\">\r\n                  <strong>{{ t(\"LOBBY_MAP_OPTIONS_LABEL_DIFFICULTY\") }}:</strong>\r\n                  {{ getBotDifficultyText() }}\r\n                </p>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"invites lolblock\" v-if=\"!isBotGame\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_INVITES_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div\r\n                class=\"invite\"\r\n                v-for=\"(invite, index) in lobbyInvites\"\r\n                :key=\"index\"\r\n              >\r\n                <span>{{ index }}</span>\r\n                <span :class=\"invite.toLowerCase()\">\r\n                  {{ getInviteStatus(invite) }}\r\n                </span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n          <div class=\"ai-info lolblock\" v-if=\"isBotGame\">\r\n            <div class=\"head\">\r\n              {{ t(\"LOBBY_AI_INFO_TITLE\") }}\r\n            </div>\r\n            <div class=\"inner\">\r\n              <div class=\"ai-difficulty-info\">\r\n                <i class=\"fas fa-robot\"></i>\r\n                <span>{{ getBotDifficultyDescription() }}</span>\r\n              </div>\r\n              <div class=\"ai-teamsize-info\">\r\n                <i class=\"fas fa-users\"></i>\r\n                <span>{{ t(\"LOBBY_AI_TEAM_SIZE\") }}: {{ getTeamSize() }}</span>\r\n              </div>\r\n              <div class=\"ai-players-count\">\r\n                <i class=\"fas fa-user-friends\"></i>\r\n                <span>{{ t(\"LOBBY_AI_PLAYERS_COUNT\") }}: {{ humanPlayersCount }}/{{ getMaxPlayers() }}</span>\r\n              </div>\r\n              <div class=\"ai-warning\" v-if=\"!canStartBotGame\">\r\n                <i class=\"fas fa-exclamation-triangle\"></i>\r\n                <span>{{ t(\"LOBBY_AI_NEED_PLAYERS\") }}</span>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n      </div>\r\n    </div>\r\n    <SideBar />\r\n  </div>\r\n</template>\r\n\r\n<script>\r\nimport Player from \"@/components/Lobby/Player.vue\";\r\nimport SideBar from \"@/components/SideBar.vue\";\r\nimport ChatMessage from \"@/components/Lobby/ChatMessage.vue\";\r\nimport { mapState } from \"vuex\";\r\n\r\nexport default {\r\n  components: {\r\n    Player,\r\n    ChatMessage,\r\n    SideBar\r\n  },\r\n  data() {\r\n    return {\r\n      lastMessages: null,\r\n      queueNumber: \"-\"\r\n    };\r\n  },\r\n  computed: {\r\n    isTeamFull() {\r\n      if (this.players1 && this.players2) {\r\n        let user = this.$store.state.user.summonerName;\r\n        let team1 = this.players1.some(c => c.summonerName == user);\r\n        let team2 = this.players2.some(c => c.summonerName == user);\r\n\r\n        if (team1 && this.players2.length <= 5) {\r\n          return false;\r\n        } else if (team2 && this.players1.length <= 5) {\r\n          return false;\r\n        }\r\n      }\r\n      return true;\r\n    },\r\n    ...mapState({\r\n      players1: state =>\r\n        state.lobby.members\r\n          ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM1\")\r\n          : undefined,\r\n      players2: state =>\r\n        state.lobby.members\r\n          ? state.lobby.members.filter(c => c.lobbyTeam === \"TEAM2\")\r\n          : undefined,\r\n      lobbyChatMessages: state => state.lobbyChatMessages,\r\n      lobbyInvites: state => state.lobby.invited,\r\n      inQueue: state => state.lobby.inQueue,\r\n      owner: state => state.lobbyOwner,\r\n      serverCount: state => state.serverCount,\r\n      isBotGame: state => state.lobby.isBotGame || false,\r\n      botDifficulty: state => state.lobby.botDifficulty,\r\n      currentLobbyPlayer: state => {\r\n        return state.lobby.members.filter(member => {\r\n          return member.summonerName == state.user.summonerName;\r\n        })[0];\r\n      },\r\n      isHumanPlayer: state => {\r\n        if (!state.lobby.isBotGame) return true;\r\n        const currentUser = state.user.summonerName;\r\n        return state.lobby.members.some(member => \r\n          member.summonerName === currentUser && !member.isAI\r\n        );\r\n      },\r\n      humanPlayersCount: state => {\r\n        if (!state.lobby.isBotGame) return 0;\r\n        return state.lobby.members.filter(member => !member.isAI).length;\r\n      },\r\n      canStartBotGame: state => {\r\n        if (!state.lobby.isBotGame) return true;\r\n        return state.lobby.members.some(member => !member.isAI);\r\n      }\r\n    })\r\n  },\r\n  methods: {\r\n    getMaxPlayers() {\r\n      const teamSize = this.getTeamSize();\r\n      if (teamSize === \"5x5\") return 5;\r\n      if (teamSize === \"3x3\") return 3;\r\n      return 5;\r\n    },\r\n    isTeamAI(teamNumber) {\r\n      const team = teamNumber === 1 ? this.players1 : this.players2;\r\n      if (!team || team.length === 0) return false;\r\n      // 检查队伍是否全部是AI\r\n      return team.every(player => player.isAI === true);\r\n    },\r\n    getBotDifficultyText() {\r\n      const difficulties = {\r\n        BEGINNER: this.$translate.text(\"PLAY_DATA_DIFFICULTY_BEGINNER\"),\r\n        INTERMEDIATE: this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\"),\r\n        ADVANCED: this.$translate.text(\"PLAY_DATA_DIFFICULTY_ADVANCED\")\r\n      };\r\n      return difficulties[this.botDifficulty] || this.botDifficulty || this.$translate.text(\"PLAY_DATA_DIFFICULTY_INTERMEDIATE\");\r\n    },\r\n    getBotDifficultyDescription() {\r\n      const descriptions = {\r\n        BEGINNER: this.$translate.text(\"LOBBY_AI_DIFFICULTY_BEGINNER_DESC\"),\r\n        INTERMEDIATE: this.$translate.text(\"LOBBY_AI_DIFFICULTY_INTERMEDIATE_DESC\"),\r\n        ADVANCED: this.$translate.text(\"LOBBY_AI_DIFFICULTY_ADVANCED_DESC\")\r\n      };\r\n      return descriptions[this.botDifficulty] || this.$translate.text(\"LOBBY_AI_DEFAULT_DESC\");\r\n    },\r\n    getStartButtonText() {\r\n      if (this.isBotGame) {\r\n        if (!this.canStartBotGame) {\r\n          return this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS\");\r\n        }\r\n        return this.$translate.text(\"CTLOBBY_START_GAME_BTN\");\r\n      }\r\n      return this.$translate.text(\"CTLOBBY_START_GAME_BTN\");\r\n    },\r\n    getChatPlaceholder() {\r\n      if (this.isBotGame && !this.isHumanPlayer) {\r\n        return this.$translate.text(\"LOBBY_AI_CANNOT_CHAT\");\r\n      }\r\n      return this.$translate.text(\"LOBBY_ALLCHAT_PLACEHOLDER\");\r\n    },\r\n    canJoinTeam(team) {\r\n      if (this.isBotGame) return false; // 人机模式不允许切换队伍\r\n      if (this.players1 && this.players2) {\r\n        if (team == 2) {\r\n          return (\r\n            this.players2.length != 5 &&\r\n            this.currentLobbyPlayer.lobbyTeam == \"TEAM1\" &&\r\n            !this.isTeamFull\r\n          );\r\n        } else {\r\n          return (\r\n            this.players1.length != 5 &&\r\n            this.currentLobbyPlayer.lobbyTeam == \"TEAM2\" &&\r\n            !this.isTeamFull\r\n          );\r\n        }\r\n      } else {\r\n        return false;\r\n      }\r\n    },\r\n    getInviteStatus(status) {\r\n      return this.$translate.text(`LOBBY_INVITE_STATUS_${status}`);\r\n    },\r\n    inLobby(invite) {\r\n      return (\r\n        this.$store.state.lobby.members.filter(member => {\r\n          return member.summonerName == invite.summonerName;\r\n        }).length > 0\r\n      );\r\n    },\r\n    getQueueType() {\r\n      if (this.isBotGame) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_BOT\");\r\n      }\r\n      switch (this.$store.state.lobby.lobbyType) {\r\n        case \"SUMMONERS_RIFT_DRAFT\":\r\n        case \"TWISTED_TREELINE_DRAFT\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_DRAFT\");\r\n        case \"SUMMONERS_RIFT_BLIND\":\r\n        case \"TWISTED_TREELINE_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_BLIND\");\r\n        case \"ARAM_BLIND\":\r\n          return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_QT_ARAM\");\r\n        default:\r\n          return \"\";\r\n      }\r\n    },\r\n    getMapPreview() {\r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\r\n        return \"static/images/general/sr-preview.png\";\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return \"static/images/general/tt-preview.png\";\r\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\r\n        return \"static/images/general/ha-preview.png\";\r\n      }\r\n      return \"static/images/general/sr-preview.png\";\r\n    },\r\n    getMapType() {\r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && lobbyType.includes(\"SUMMONERS_RIFT\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_TT\");\r\n      } else if (lobbyType && lobbyType.includes(\"ARAM\")) {\r\n        return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_HA\");\r\n      }\r\n      return this.$translate.text(\"LOBBY_MAP_OPTIONS_VALUE_SR\");\r\n    },\r\n    getTeamSize() {\r\n      const lobbyType = this.$store.state.lobby.lobbyType;\r\n      if (lobbyType && (lobbyType.includes(\"SUMMONERS_RIFT\") || lobbyType.includes(\"ARAM\"))) {\r\n        return \"5x5\";\r\n      } else if (lobbyType && lobbyType.includes(\"TWISTED_TREELINE\")) {\r\n        return \"3x3\";\r\n      }\r\n      return \"5x5\";\r\n    },\r\n    sendLobbyChatMessage() {\r\n      if (this.isBotGame && !this.isHumanPlayer) {\r\n        return;\r\n      }\r\n      const message = this.$refs.chatInput.value;\r\n      if (message.trim() == \"\") return;\r\n      this.$refs.chatInput.value = \"\";\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_CHAT\",\r\n        { data: message },\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n          this.$nextTick(() => {\r\n            if (this.$refs.chatMessages) {\r\n              this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n            }\r\n          });\r\n        }\r\n      );\r\n    },\r\n    leaveLobby() {\r\n      const route = this.$route.name;\r\n      const router = this.$router;\r\n      this.$socket.sendLobbyMessage(\"LOBBY_LEAVE\", {}, (response, error) => {\r\n        if (error) {\r\n          console.log(\"Flyback error:\");\r\n          console.log(error);\r\n        }\r\n        if (route != \"Home\") {\r\n          router.push(\"/LoggedIn/home\");\r\n        }\r\n      });\r\n    },\r\n    startQueue() {\r\n      if (this.inQueue) return;\r\n      \r\n      if (this.isBotGame) {\r\n        if (!this.canStartBotGame) {\r\n          this.$modal.setter.show({\r\n            title: this.$translate.text(\"LOBBY_CANNOT_START\"),\r\n            body: this.$translate.text(\"LOBBY_NEED_MORE_PLAYERS_DETAIL\"),\r\n            footer: this.$translate.text(\"GENERAL_OK\")\r\n          });\r\n          return;\r\n        }\r\n        \r\n        this.$socket.sendLobbyMessage(\r\n          \"LOBBY_START_BOT_GAME\",\r\n          { data: { difficulty: this.botDifficulty } },\r\n          (response, error) => {\r\n            if (error) {\r\n              console.log(\"Flyback error:\");\r\n              console.log(error);\r\n              this.$modal.setter.show({\r\n                title: this.$translate.text(\"LOBBY_START_FAILED\"),\r\n                body: error.message || this.$translate.text(\"LOBBY_START_FAILED_DESC\"),\r\n                footer: this.$translate.text(\"GENERAL_OK\")\r\n              });\r\n            }\r\n          }\r\n        );\r\n        return;\r\n      }\r\n\r\n      this.$sound.template(\"OVERVIEW_PLAYBUTTON\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_START\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n\r\n            if (error && error.message && error.code === 140) {\r\n              this.$store.dispatch(\"socketRecievedLobbyChat\", {\r\n                from: \"SYSTEM\",\r\n                to: null,\r\n                data: error.message\r\n              });\r\n            }\r\n          }\r\n\r\n          console.log(response);\r\n        }\r\n      );\r\n    },\r\n    stopQueue() {\r\n      this.$sound.template(\"OVERVIEW_CLICK\");\r\n      this.$store.dispatch(\"clearLobbyTimers\");\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_MATCHMAKING_STOP\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n          this.$store.dispatch(\"setLobbyQueueState\", false);\r\n\r\n          console.log(response);\r\n        }\r\n      );\r\n    },\r\n    switchTeam() {\r\n      if (this.inQueue) return;\r\n\r\n      this.$socket.sendLobbyMessage(\r\n        \"LOBBY_SWITCH_TEAM\",\r\n        {},\r\n        (response, error) => {\r\n          if (error) {\r\n            console.log(\"Flyback error:\");\r\n            console.log(error);\r\n          }\r\n        }\r\n      );\r\n    },\r\n    t(key, params) {\r\n      return this.$translate.text(key, params);\r\n    },\r\n    tWithParams(key, params) {\r\n      return this.$translate.text(key, params);\r\n    }\r\n  },\r\n  beforeMount() {\r\n    this.$store.dispatch(\"saveUserStatus\", \"IN_LOBBY\");\r\n    this.$store.dispatch(\"changeBackgroundState\", \"CUSTOM_LOBBY\");\r\n  },\r\n  mounted() {\r\n    this.$nextTick(() => {\r\n      if (this.$refs.chatMessages) {\r\n        this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n      }\r\n    });\r\n  },\r\n  updated() {\r\n    if (this.lastMessages !== this.lobbyChatMessages.length) {\r\n      this.lastMessages = this.lobbyChatMessages.length;\r\n      this.$nextTick(() => {\r\n        if (this.$refs.chatMessages) {\r\n          this.$refs.chatMessages.scrollTop = this.$refs.chatMessages.scrollHeight;\r\n        }\r\n      });\r\n    }\r\n  },\r\n  created() {\r\n    this.$store.dispatch(\"getServerCount\");\r\n  }\r\n};\r\n</script>\r\n\r\n<style lang=\"css\" scoped>\r\n#LobbyCustom {\r\n  width: 100%;\r\n  height: calc(100% - 115px);\r\n  margin-top: 77px;\r\n  position: relative;\r\n  z-index: 0;\r\n  display: flex;\r\n}\r\n\r\n#LobbyCustom .content {\r\n  width: 100%;\r\n  position: relative;\r\n  display: flex;\r\n  justify-content: flex-end;\r\n}\r\n#LobbyCustom .sidebar-holder {\r\n  width: 20%;\r\n  position: absolute;\r\n  right: 0;\r\n  top: 0;\r\n}\r\n\r\n.content .mainblock {\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n}\r\n\r\n.lolblock {\r\n  display: flex;\r\n  flex-direction: column;\r\n  width: 100%;\r\n  height: 100%;\r\n  border: 1px solid rgba(100, 117, 137, 0.75);\r\n  border-radius: 5px;\r\n  overflow: hidden;\r\n}\r\n\r\n.lolblock .head {\r\n  height: 30px;\r\n  width: 100%;\r\n  font-size: 14px;\r\n  font-family: LoLFont2;\r\n  padding: 5px;\r\n  background-image: linear-gradient(\r\n    180deg,\r\n    #192e49 0%,\r\n    #192e49 40%,\r\n    #172b46 50%,\r\n    #142131 100%\r\n  );\r\n}\r\n\r\n.lolblock .inner {\r\n  background-color: rgba(5, 12, 20, 0.85);\r\n  width: 100%;\r\n  height: calc(100% - 30px);\r\n  position: relative;\r\n}\r\n\r\n.content .mainblock .lobby {\r\n  width: 100%;\r\n  height: 100%;\r\n  display: flex;\r\n  flex-direction: column;\r\n  justify-content: space-between;\r\n}\r\n\r\n.content .mainblock .lobby .players {\r\n  width: 100%;\r\n  height: 70%;\r\n  display: flex;\r\n  position: relative;\r\n}\r\n\r\n.content .mainblock .lobby .p